---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Split PDF Free, 100% In Your Browser, No Upload | Toolbase';
const description =
	'Split one PDF into multiple files, by custom page ranges, every N pages, or one file per page. Downloads as a zip when there is more than one. Runs entirely in your browser; your file is never uploaded. Free, unlimited, no sign-up.';

const faqs = [
	{
		q: 'Is my PDF uploaded anywhere?',
		a: 'No. The split happens inside your browser on your own device. Your PDF is never sent over the internet or stored on a server, which makes it safe for confidential documents and means it keeps working even if your connection drops.',
	},
	{
		q: 'How do I split a PDF into separate files?',
		a: 'Add your PDF, choose how to split it, custom ranges like 1-3, 4-6, 7-10 (each group becomes its own file), every N pages, or one file per page, then click Split. If the result is more than one file you get a single zip containing all of them.',
	},
	{
		q: 'Can I extract just a few pages from a PDF?',
		a: 'Yes. Use "Custom ranges" and enter the pages you want, e.g. 2-5. A single range produces a single PDF with just those pages, so it doubles as a page-extractor.',
	},
	{
		q: 'What is the difference between this and the Merge tool?',
		a: 'Splitting takes one PDF apart into several files; merging combines several files into one. They are opposites and pair naturally, split a document, edit the parts, then merge them back together, all without ever uploading anything.',
	},
	{
		q: 'Is there a page or file size limit?',
		a: 'No artificial limit, no signup, no daily cap, no watermark. Everything runs on your device, so the only real ceiling is your computer’s memory. Typical documents split in a second or two.',
	},
];

const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
});

const appJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Split PDF',
	applicationCategory: 'UtilitiesApplication',
	operatingSystem: 'Any (web browser)',
	url: 'https://gettoolbase.org/tools/split-pdf/',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	description: description,
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://gettoolbase.org/tools/' },
		{ '@type': 'ListItem', position: 3, name: 'Split PDF', item: 'https://gettoolbase.org/tools/split-pdf/' },
	],
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={faqJsonLd} />
		<script type="application/ld+json" is:inline set:html={appJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/tools/">Tools</a> › <span>Split PDF</span>
			</nav>

			<h1>Split PDF</h1>
			<p class="lede">
				Break one PDF into multiple files, by custom page ranges, every N pages, or one file per page.
				<strong>Everything happens in your browser:</strong> your file is never uploaded, never sent
				anywhere, never stored. Free, unlimited, no sign-up.
			</p>

			<section class="app" aria-label="Split PDF tool">
				<div id="drop" class="drop" tabindex="0" role="button" aria-label="Add a PDF file">
					<p class="drop-big">Drop a PDF here</p>
					<p class="drop-sub">or <span class="link">browse your device</span></p>
					<input id="file-input" type="file" accept="application/pdf" hidden />
				</div>

				<div id="loaded" class="loaded" hidden>
					<div class="file-row">
						<span class="badge pdf">PDF</span>
						<span class="meta"><span class="fname" id="fname"></span><span class="fsub" id="fsub"></span></span>
						<button id="change-btn" type="button" class="rb" aria-label="Choose a different file">✕</button>
					</div>

					<fieldset class="modes">
						<legend>How should it be split?</legend>
						<label class="mode"><input type="radio" name="mode" value="ranges" checked /> <span>Custom ranges <small>each group → one file, e.g. <code>1-3, 4-6, 7-10</code></small></span></label>
						<div class="mode-input" id="ranges-input">
							<input id="ranges" type="text" placeholder="1-3, 4-6, 7-10" />
						</div>
						<label class="mode"><input type="radio" name="mode" value="every" /> <span>Every N pages <small>fixed-size chunks</small></span></label>
						<div class="mode-input" id="every-input" hidden>
							<input id="every-n" type="number" min="1" step="1" value="1" /> <span class="suffix">pages per file</span>
						</div>
						<label class="mode"><input type="radio" name="mode" value="each" /> <span>One file per page <small>splits into individual pages</small></span></label>
					</fieldset>

					<div class="actions">
						<button id="split-btn" type="button" class="primary">Split &amp; Download</button>
						<span id="status" class="status" aria-live="polite"></span>
					</div>
				</div>

				<p class="privacy">🔒 100% private, processed locally in your browser. Nothing is uploaded.</p>
			</section>

			<div class="prose">
				<h2>How to split a PDF in your browser</h2>
				<ol>
					<li><strong>Add your PDF.</strong> Drop it in or browse, it stays on your device.</li>
					<li><strong>Choose a split method.</strong> Custom ranges, every N pages, or one file per page.</li>
					<li><strong>Split &amp; download.</strong> One file downloads directly; multiple files come back as a single zip.</li>
				</ol>

				<h2>Why split PDFs in the browser instead of an online uploader?</h2>
				<p>
					Most free PDF splitters upload your document to their servers, cap how many files you can make,
					or push a signup. For anything sensitive, contracts, statements, scans of IDs, that's a real
					privacy risk. This tool runs entirely on your own device, so the file never travels over the
					internet, there are no limits, and it works even offline once the page has loaded. It pairs with
					the <a href="/tools/merge-pdf/">Merge PDF</a> tool: split a document apart, then merge the pieces
					back when you're done.
				</p>

				<h2>Frequently asked questions</h2>
				{
					faqs.map((f) => (
						<details class="faq">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>

			<!--
				MONETIZATION: outbound links are affiliate-ready.
				Swap each href for the tracked affiliate URL on approval and change
				rel to "sponsored noopener". Until then: plain rel="nofollow noopener".
			-->
			<aside class="recommends">
				<h2>Working with PDFs a lot?</h2>
				<p>Tools worth knowing when you outgrow the basics:</p>
				<ul>
					<li><a href="/tools/merge-pdf/">Merge PDF</a>, the opposite of this tool, also 100% in your browser.</li>
					<li><a href="https://www.adobe.com/acrobat/online.html" rel="nofollow noopener" target="_blank">Adobe Acrobat online</a>, when you need OCR, redaction or e-signatures.</li>
				</ul>
				<p class="tiny">We only list tools we'd use ourselves. Some links may become affiliate links, it never changes what we recommend or costs you anything.</p>
			</aside>

			<p class="back"><a href="/tools/">← All Toolbase tools</a></p>
		</main>
		<Footer />

		<script>
			// pdf-lib (~180KB gz) and jszip load lazily, only when a file is added,
			// so search visitors who bounce never download them.
			let _pdfLibPromise = null;
			function loadPdfLib() {
				if (!_pdfLibPromise) _pdfLibPromise = import('pdf-lib');
				return _pdfLibPromise;
			}
			let _jszipPromise = null;
			function loadJsZip() {
				if (!_jszipPromise) _jszipPromise = import('jszip');
				return _jszipPromise;
			}

			const $ = (id) => document.getElementById(id);
			const drop = $('drop');
			const input = $('file-input');
			const loaded = $('loaded');
			const statusEl = $('status');

			let current = null; // { file, bytes, total, base }

			function fmtSize(b) {
				if (b < 1024) return b + ' B';
				if (b < 1024 * 1024) return (b / 1024).toFixed(0) + ' KB';
				return (b / 1024 / 1024).toFixed(1) + ' MB';
			}

			async function setFile(file) {
				if (!file) return;
				setBusy(true, 'Reading…');
				try {
					const { PDFDocument } = await loadPdfLib();
					const bytes = new Uint8Array(await file.arrayBuffer());
					const doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
					const total = doc.getPageCount();
					const base = file.name.replace(/\.pdf$/i, '') || 'document';
					current = { file, bytes, total, base };
					$('fname').textContent = file.name;
					$('fsub').textContent = total + ' pages · ' + fmtSize(file.size);
					$('every-n').max = String(total);
					loaded.hidden = false;
					drop.hidden = true;
					setBusy(false, '');
				} catch (err) {
					console.error(err);
					current = null;
					setBusy(false, '⚠ Could not read that PDF.');
				}
			}

			// "1-3" or "5" -> array of 0-based indices within [0,total)
			function parsePart(part, total) {
				const p = part.trim();
				const out = [];
				const m = p.match(/^(\d+)\s*-\s*(\d+)$/);
				if (m) {
					let a = parseInt(m[1], 10),
						b = parseInt(m[2], 10);
					if (a > b) [a, b] = [b, a];
					for (let n = a; n <= b; n++) if (n >= 1 && n <= total) out.push(n - 1);
				} else if (/^\d+$/.test(p)) {
					const n = parseInt(p, 10);
					if (n >= 1 && n <= total) out.push(n - 1);
				} else {
					throw new Error('Invalid range: "' + p + '"');
				}
				if (out.length === 0) throw new Error('Range "' + p + '" matched no pages');
				return out;
			}

			// returns array of groups; each group is an array of 0-based page indices
			function computeGroups(mode, total, rangesStr, n) {
				if (mode === 'each') return Array.from({ length: total }, (_, i) => [i]);
				if (mode === 'every') {
					if (!(n >= 1)) throw new Error('Enter a valid number of pages');
					const groups = [];
					for (let i = 0; i < total; i += n) {
						const g = [];
						for (let j = i; j < Math.min(i + n, total); j++) g.push(j);
						groups.push(g);
					}
					return groups;
				}
				// ranges
				const s = (rangesStr || '').trim();
				if (!s) throw new Error('Enter at least one page range');
				const groups = s.split(',').map((part) => parsePart(part, total)).filter((g) => g.length);
				if (groups.length === 0) throw new Error('No valid ranges');
				return groups;
			}

			function labelForGroup(group, idx) {
				const first = group[0] + 1;
				const last = group[group.length - 1] + 1;
				return first === last ? 'p' + first : 'p' + first + '-' + last;
			}

			async function split() {
				if (!current) return;
				const mode = document.querySelector('input[name="mode"]:checked').value;
				setBusy(true, 'Splitting…');
				try {
					const { PDFDocument } = await loadPdfLib();
					const groups = computeGroups(mode, current.total, $('ranges').value, parseInt($('every-n').value, 10));

					const outputs = [];
					for (let i = 0; i < groups.length; i++) {
						const src = await PDFDocument.load(current.bytes, { ignoreEncryption: true });
						const doc = await PDFDocument.create();
						const copied = await doc.copyPages(src, groups[i]);
						copied.forEach((p) => doc.addPage(p));
						const data = await doc.save();
						outputs.push({ name: current.base + '_' + labelForGroup(groups[i], i) + '.pdf', data });
					}

					if (outputs.length === 1) {
						downloadBlob(outputs[0].data, outputs[0].name, 'application/pdf');
						setBusy(false, '✓ Extracted ' + groups[0].length + ' pages, downloaded.');
					} else {
						const JSZip = (await loadJsZip()).default;
						const zip = new JSZip();
						outputs.forEach((o) => zip.file(o.name, o.data));
						const blob = await zip.generateAsync({ type: 'blob' });
						downloadBlobObject(blob, current.base + '_split.zip');
						setBusy(false, '✓ Split into ' + outputs.length + ' files, downloaded as zip.');
					}
				} catch (err) {
					console.error(err);
					setBusy(false, '⚠ ' + (err && err.message ? err.message : 'Something went wrong.'));
				}
			}

			function downloadBlob(data, name, type) {
				downloadBlobObject(new Blob([data], { type }), name);
			}
			function downloadBlobObject(blob, name) {
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				a.download = name;
				document.body.appendChild(a);
				a.click();
				a.remove();
				setTimeout(() => URL.revokeObjectURL(url), 5000);
			}

			function setBusy(busy, msg) {
				$('split-btn').disabled = busy;
				statusEl.textContent = msg || '';
				statusEl.className = 'status' + (msg && msg[0] === '⚠' ? ' err' : '');
			}

			// wire up
			drop.addEventListener('click', () => input.click());
			drop.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' || e.key === ' ') {
					e.preventDefault();
					input.click();
				}
			});
			input.addEventListener('change', (e) => {
				if (e.target.files[0]) setFile(e.target.files[0]);
				input.value = '';
			});
			['dragover', 'dragenter'].forEach((ev) =>
				drop.addEventListener(ev, (e) => {
					e.preventDefault();
					drop.classList.add('over');
				})
			);
			['dragleave', 'drop'].forEach((ev) =>
				drop.addEventListener(ev, (e) => {
					e.preventDefault();
					drop.classList.remove('over');
				})
			);
			drop.addEventListener('drop', (e) => {
				if (e.dataTransfer && e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]);
			});
			$('change-btn').addEventListener('click', () => {
				current = null;
				loaded.hidden = true;
				drop.hidden = false;
				setBusy(false, '');
			});
			$('split-btn').addEventListener('click', split);
			document.querySelectorAll('input[name="mode"]').forEach((r) =>
				r.addEventListener('change', () => {
					const mode = document.querySelector('input[name="mode"]:checked').value;
					$('ranges-input').hidden = mode !== 'ranges';
					$('every-input').hidden = mode !== 'every';
				})
			);
		</script>

		<style>
			.crumbs {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
			}
			.crumbs a {
				color: rgb(var(--gray));
			}
			.lede {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
			}
			.app {
				margin: 2em 0 3em;
			}
			.drop {
				border: 2px dashed rgb(var(--gray));
				border-radius: 14px;
				padding: 2.5em 1em;
				text-align: center;
				cursor: pointer;
				background: #fff;
				transition: border-color 0.15s ease, background 0.15s ease;
			}
			.drop:hover,
			.drop:focus,
			.drop.over {
				border-color: var(--accent);
				background: rgba(35, 55, 255, 0.04);
				outline: none;
			}
			.drop-big {
				font-size: 1.3em;
				font-weight: 700;
				margin: 0 0 0.25em;
			}
			.drop-sub {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.drop .link {
				color: var(--accent);
				text-decoration: underline;
			}
			.loaded {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1em 1.1em;
				background: #fff;
			}
			.file-row {
				display: flex;
				align-items: center;
				gap: 0.6em;
			}
			.badge {
				font-size: 0.65em;
				font-weight: 700;
				padding: 0.2em 0.45em;
				border-radius: 4px;
				color: #fff;
				flex: none;
			}
			.badge.pdf {
				background: #9a2515;
			}
			.meta {
				display: flex;
				flex-direction: column;
				min-width: 0;
				flex: 1;
			}
			.fname {
				font-size: 0.95em;
				font-weight: 700;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.fsub {
				font-size: 0.75em;
				color: rgb(var(--gray));
			}
			.rb {
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				border-radius: 6px;
				width: 2em;
				height: 2em;
				cursor: pointer;
				flex: none;
			}
			.rb:hover {
				border-color: #9a2515;
				color: #9a2515;
			}
			.modes {
				border: none;
				margin: 1.25em 0 0;
				padding: 0;
			}
			.modes legend {
				font-weight: 700;
				font-size: 0.9em;
				padding: 0;
				margin-bottom: 0.5em;
			}
			.mode {
				display: flex;
				align-items: flex-start;
				gap: 0.5em;
				padding: 0.5em 0;
				cursor: pointer;
				font-size: 0.95em;
			}
			.mode small {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.78em;
				font-weight: 400;
			}
			.mode-input {
				padding: 0 0 0.5em 1.6em;
			}
			.mode-input input[type='text'] {
				width: 16em;
				max-width: 100%;
			}
			.mode-input input {
				padding: 0.45em 0.6em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				font-size: 0.9em;
			}
			.mode-input input:focus {
				outline: 2px solid var(--accent);
				border-color: var(--accent);
			}
			.mode-input .suffix {
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.actions {
				display: flex;
				align-items: center;
				gap: 0.75em;
				margin-top: 1em;
				flex-wrap: wrap;
			}
			button.primary {
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 8px;
				padding: 0.7em 1.4em;
				font-size: 1em;
				font-weight: 700;
				cursor: pointer;
			}
			button.primary:disabled {
				opacity: 0.6;
				cursor: default;
			}
			.status {
				font-size: 0.85em;
				color: #0d7a3f;
				font-weight: 700;
			}
			.status.err {
				color: #9a2515;
			}
			.privacy {
				margin: 1em 0 0;
				font-size: 0.82em;
				color: rgb(var(--gray-dark));
			}
			.prose h2 {
				margin-top: 1.5em;
			}
			.prose .faq {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.75em 1em;
				margin-bottom: 0.6em;
			}
			.prose .faq summary {
				cursor: pointer;
				font-weight: 700;
				font-size: 0.95em;
			}
			.prose .faq p {
				margin: 0.75em 0 0;
				font-size: 0.92em;
			}
			.recommends {
				background: rgba(var(--gray-light), 40%);
				border-radius: 12px;
				padding: 1.25em 1.5em;
				margin: 2.5em 0;
			}
			.recommends h2 {
				margin-top: 0;
				font-size: 1.6em;
			}
			.recommends .tiny {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin-bottom: 0;
			}
			.back {
				margin-top: 2em;
			}
		</style>
	</body>
</html>
