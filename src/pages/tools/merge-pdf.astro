---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Merge PDF Free — 100% In Your Browser, No Upload | Toolbase';
const description =
	'Combine PDFs (and JPG/PNG images) into one file — right in your browser. Reorder files, pull out specific page ranges, and download. Your files are never uploaded to a server. Free, unlimited, no sign-up.';

const faqs = [
	{
		q: 'Are my files uploaded to a server?',
		a: 'No. This tool does the entire merge inside your browser using your device’s own processing. Your PDFs and images never leave your computer, are never sent over the internet, and are never stored anywhere. That is also why it works on confidential documents and keeps running even if your connection drops.',
	},
	{
		q: 'How do I merge multiple PDFs into one?',
		a: 'Add the files, drag-free reorder them with the up/down arrows into the order you want, then click Merge & Download. The tool stitches them into a single PDF in that order and saves it to your device.',
	},
	{
		q: 'Can I merge only certain pages from a PDF?',
		a: 'Yes. Each PDF has a "pages" box — leave it as "all", or type a range like 1-3, 5, 8-10 to include only those pages. It is an instant way to split or extract pages while merging, without a separate tool.',
	},
	{
		q: 'Can I combine images into a PDF?',
		a: 'Yes. Add JPG or PNG files alongside (or instead of) PDFs and each image becomes its own page in the merged PDF, in the order you arrange them. It doubles as a free JPG-to-PDF converter.',
	},
	{
		q: 'Is there a file size or file count limit?',
		a: 'There is no artificial limit — no signup, no daily cap, no watermark. The only real ceiling is your device’s memory, since everything runs locally. Very large files (hundreds of MB) may be slow on older machines, but typical documents merge in a second or two.',
	},
];

const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
});

const appJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Merge PDF',
	applicationCategory: 'UtilitiesApplication',
	operatingSystem: 'Any (web browser)',
	url: 'https://gettoolbase.org/tools/merge-pdf/',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	description: description,
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://gettoolbase.org/tools/' },
		{ '@type': 'ListItem', position: 3, name: 'Merge PDF', item: 'https://gettoolbase.org/tools/merge-pdf/' },
	],
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={faqJsonLd} />
		<script type="application/ld+json" is:inline set:html={appJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/tools/">Tools</a> › <span>Merge PDF</span>
			</nav>

			<h1>Merge PDF</h1>
			<p class="lede">
				Combine PDFs and images into one file — reorder them, pull out specific pages, and download.
				<strong>Everything happens in your browser:</strong> your files are never uploaded, never sent
				anywhere, never stored. Free, unlimited, no sign-up.
			</p>

			<section class="app" aria-label="Merge PDF tool">
				<div id="drop" class="drop" tabindex="0" role="button" aria-label="Add PDF or image files">
					<p class="drop-big">Drop PDFs or images here</p>
					<p class="drop-sub">or <span class="link">browse your device</span> — PDF, JPG, PNG</p>
					<input id="file-input" type="file" accept="application/pdf,image/jpeg,image/png" multiple hidden />
				</div>

				<ul id="file-list" class="file-list"></ul>

				<div id="actions" class="actions" hidden>
					<button id="merge-btn" type="button" class="primary">Merge &amp; Download</button>
					<button id="clear-btn" type="button" class="ghost">Clear all</button>
					<span id="status" class="status" aria-live="polite"></span>
				</div>

				<p class="privacy">🔒 100% private — processed locally in your browser. Nothing is uploaded.</p>
			</section>

			<div class="prose">
				<h2>How to merge PDF files in your browser</h2>
				<ol>
					<li><strong>Add your files.</strong> Drop in PDFs, JPGs or PNGs — as many as you like.</li>
					<li><strong>Put them in order.</strong> Use the arrows to arrange the files top-to-bottom.</li>
					<li><strong>Pick pages (optional).</strong> For any PDF, type a range like <code>1-3, 5</code> to include only those pages.</li>
					<li><strong>Merge &amp; download.</strong> One click builds a single PDF and saves it — no upload, no waiting on a server.</li>
				</ol>

				<h2>Why merge PDFs in the browser instead of an online uploader?</h2>
				<p>
					Most "free" PDF mergers upload your documents to their servers, cap you at a few files a day,
					stamp a watermark, or push you to sign up. That's a privacy risk for anything confidential —
					contracts, IDs, financials — and it's slow. This tool runs entirely on your own device using
					your browser's built-in capabilities, so your files never travel over the internet, there are
					no limits, and it keeps working even offline once the page has loaded.
				</p>

				<h2>Frequently asked questions</h2>
				{
					faqs.map((f) => (
						<details class="faq">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>

			<!--
				MONETIZATION: outbound links are affiliate-ready.
				Swap each href for the tracked affiliate URL on approval and change
				rel to "sponsored noopener". Until then: plain rel="nofollow noopener".
			-->
			<aside class="recommends">
				<h2>Working with PDFs a lot?</h2>
				<p>Tools worth knowing when you outgrow the basics:</p>
				<ul>
					<li><a href="https://www.adobe.com/acrobat/online.html" rel="nofollow noopener" target="_blank">Adobe Acrobat online</a> — when you need OCR, redaction or e-signatures.</li>
					<li><a href="https://www.pdfgear.com/" rel="nofollow noopener" target="_blank">PDFgear</a> — free desktop editor for heavier offline work.</li>
				</ul>
				<p class="tiny">We only list tools we'd use ourselves. Some links may become affiliate links — it never changes what we recommend or costs you anything.</p>
			</aside>

			<p class="back"><a href="/tools/">← All Toolbase tools</a></p>
		</main>
		<Footer />

		<script>
			// pdf-lib is ~180KB gzipped. Load it lazily so visitors who never use the
			// tool (landed from search, bounced) never pay for it. Kicked off on first
			// file add so it's usually ready by the time they hit Merge.
			let _pdfLibPromise = null;
			function loadPdfLib() {
				if (!_pdfLibPromise) _pdfLibPromise = import('pdf-lib');
				return _pdfLibPromise;
			}

			let items = [];
			let seq = 0;

			const $ = (id) => document.getElementById(id);
			const drop = $('drop');
			const input = $('file-input');
			const list = $('file-list');
			const actions = $('actions');
			const statusEl = $('status');

			function fmtSize(bytes) {
				if (bytes < 1024) return bytes + ' B';
				if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
				return (bytes / 1024 / 1024).toFixed(1) + ' MB';
			}
			function kindOf(file) {
				if (file.type === 'application/pdf' || /\.pdf$/i.test(file.name)) return 'pdf';
				if (file.type === 'image/jpeg' || /\.jpe?g$/i.test(file.name)) return 'jpg';
				if (file.type === 'image/png' || /\.png$/i.test(file.name)) return 'png';
				return null;
			}

			function addFiles(fileList) {
				let added = false;
				for (const file of fileList) {
					const kind = kindOf(file);
					if (!kind) continue;
					items.push({ id: ++seq, file, kind, range: '' });
					added = true;
				}
				if (added) loadPdfLib(); // warm up the library in the background
				render();
			}

			function move(id, dir) {
				const i = items.findIndex((x) => x.id === id);
				const j = i + dir;
				if (i < 0 || j < 0 || j >= items.length) return;
				[items[i], items[j]] = [items[j], items[i]];
				render();
			}
			function remove(id) {
				items = items.filter((x) => x.id !== id);
				render();
			}

			function render() {
				list.innerHTML = '';
				items.forEach((it, idx) => {
					const li = document.createElement('li');
					li.className = 'file-row';
					const badge = it.kind === 'pdf' ? 'PDF' : it.kind.toUpperCase();
					li.innerHTML =
						'<span class="idx">' +
						(idx + 1) +
						'</span>' +
						'<span class="badge ' +
						it.kind +
						'">' +
						badge +
						'</span>' +
						'<span class="meta"><span class="fname"></span><span class="fsize">' +
						fmtSize(it.file.size) +
						'</span></span>' +
						(it.kind === 'pdf'
							? '<input class="range" type="text" placeholder="all pages" aria-label="page range" value="' +
								it.range +
								'" />'
							: '<span class="range-spacer">1 page</span>') +
						'<span class="row-btns">' +
						'<button class="rb" data-act="up" aria-label="move up">↑</button>' +
						'<button class="rb" data-act="down" aria-label="move down">↓</button>' +
						'<button class="rb del" data-act="del" aria-label="remove">✕</button>' +
						'</span>';
					li.querySelector('.fname').textContent = it.file.name;
					const rangeInput = li.querySelector('.range');
					if (rangeInput)
						rangeInput.addEventListener('input', (e) => {
							it.range = e.target.value;
						});
					li.querySelector('[data-act="up"]').addEventListener('click', () => move(it.id, -1));
					li.querySelector('[data-act="down"]').addEventListener('click', () => move(it.id, 1));
					li.querySelector('[data-act="del"]').addEventListener('click', () => remove(it.id));
					list.appendChild(li);
				});
				actions.hidden = items.length === 0;
				statusEl.textContent = '';
			}

			// Parse "1-3, 5, 8-10" (1-based) -> array of 0-based indices within [0, total)
			function parseRange(str, total) {
				const s = (str || '').trim().toLowerCase();
				if (!s || s === 'all') return Array.from({ length: total }, (_, i) => i);
				const out = [];
				for (const part of s.split(',')) {
					const p = part.trim();
					if (!p) continue;
					const m = p.match(/^(\d+)\s*-\s*(\d+)$/);
					if (m) {
						let a = parseInt(m[1], 10);
						let b = parseInt(m[2], 10);
						if (a > b) [a, b] = [b, a];
						for (let n = a; n <= b; n++) if (n >= 1 && n <= total) out.push(n - 1);
					} else if (/^\d+$/.test(p)) {
						const n = parseInt(p, 10);
						if (n >= 1 && n <= total) out.push(n - 1);
					} else {
						throw new Error('Invalid page range: "' + part.trim() + '"');
					}
				}
				if (out.length === 0) throw new Error('Page range matched no pages');
				return out;
			}

			async function merge() {
				if (items.length === 0) return;
				setBusy(true, 'Merging…');
				try {
					const { PDFDocument } = await loadPdfLib();
					const out = await PDFDocument.create();
					for (const it of items) {
						const bytes = new Uint8Array(await it.file.arrayBuffer());
						if (it.kind === 'pdf') {
							const src = await PDFDocument.load(bytes, { ignoreEncryption: true });
							const total = src.getPageCount();
							const idxs = parseRange(it.range, total);
							const copied = await out.copyPages(src, idxs);
							copied.forEach((p) => out.addPage(p));
						} else {
							const img = it.kind === 'jpg' ? await out.embedJpg(bytes) : await out.embedPng(bytes);
							const page = out.addPage([img.width, img.height]);
							page.drawImage(img, { x: 0, y: 0, width: img.width, height: img.height });
						}
					}
					if (out.getPageCount() === 0) throw new Error('Nothing to merge — every page range was empty.');
					const data = await out.save();
					downloadBlob(data, 'merged.pdf');
					setBusy(false, '✓ Merged ' + out.getPageCount() + ' pages — downloaded.');
				} catch (err) {
					console.error(err);
					setBusy(false, '⚠ ' + (err && err.message ? err.message : 'Something went wrong.'));
				}
			}

			function downloadBlob(data, name) {
				const blob = new Blob([data], { type: 'application/pdf' });
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				a.download = name;
				document.body.appendChild(a);
				a.click();
				a.remove();
				setTimeout(() => URL.revokeObjectURL(url), 4000);
			}

			function setBusy(busy, msg) {
				$('merge-btn').disabled = busy;
				statusEl.textContent = msg || '';
				statusEl.className = 'status' + (msg && msg[0] === '⚠' ? ' err' : '');
			}

			// wire up
			drop.addEventListener('click', () => input.click());
			drop.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' || e.key === ' ') {
					e.preventDefault();
					input.click();
				}
			});
			input.addEventListener('change', (e) => {
				addFiles(e.target.files);
				input.value = '';
			});
			['dragover', 'dragenter'].forEach((ev) =>
				drop.addEventListener(ev, (e) => {
					e.preventDefault();
					drop.classList.add('over');
				})
			);
			['dragleave', 'drop'].forEach((ev) =>
				drop.addEventListener(ev, (e) => {
					e.preventDefault();
					drop.classList.remove('over');
				})
			);
			drop.addEventListener('drop', (e) => {
				if (e.dataTransfer && e.dataTransfer.files) addFiles(e.dataTransfer.files);
			});
			$('merge-btn').addEventListener('click', merge);
			$('clear-btn').addEventListener('click', () => {
				items = [];
				render();
			});
		</script>

		<style>
			.crumbs {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
			}
			.crumbs a {
				color: rgb(var(--gray));
			}
			.lede {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
			}
			.app {
				margin: 2em 0 3em;
			}
			.drop {
				border: 2px dashed rgb(var(--gray));
				border-radius: 14px;
				padding: 2.5em 1em;
				text-align: center;
				cursor: pointer;
				background: #fff;
				transition: border-color 0.15s ease, background 0.15s ease;
			}
			.drop:hover,
			.drop:focus,
			.drop.over {
				border-color: var(--accent);
				background: rgba(35, 55, 255, 0.04);
				outline: none;
			}
			.drop-big {
				font-size: 1.3em;
				font-weight: 700;
				margin: 0 0 0.25em;
			}
			.drop-sub {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.drop .link {
				color: var(--accent);
				text-decoration: underline;
			}
			.file-list {
				list-style: none;
				padding: 0;
				margin: 1em 0 0;
				display: grid;
				gap: 0.5em;
			}
			.file-row {
				display: flex;
				align-items: center;
				gap: 0.6em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				padding: 0.6em 0.75em;
				background: #fff;
			}
			.file-row .idx {
				font-weight: 700;
				color: rgb(var(--gray));
				width: 1.2em;
				text-align: center;
				flex: none;
			}
			.badge {
				font-size: 0.65em;
				font-weight: 700;
				padding: 0.2em 0.45em;
				border-radius: 4px;
				color: #fff;
				flex: none;
			}
			.badge.pdf {
				background: #9a2515;
			}
			.badge.jpg,
			.badge.png {
				background: #0d7a3f;
			}
			.meta {
				display: flex;
				flex-direction: column;
				min-width: 0;
				flex: 1;
			}
			.fname {
				font-size: 0.9em;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.fsize {
				font-size: 0.72em;
				color: rgb(var(--gray));
			}
			.range {
				width: 7.5em;
				flex: none;
				padding: 0.35em 0.5em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				font-size: 0.8em;
			}
			.range:focus {
				outline: 2px solid var(--accent);
				border-color: var(--accent);
			}
			.range-spacer {
				width: 7.5em;
				flex: none;
				font-size: 0.72em;
				color: rgb(var(--gray));
				text-align: center;
			}
			.row-btns {
				display: flex;
				gap: 0.25em;
				flex: none;
			}
			.rb {
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				border-radius: 6px;
				width: 2em;
				height: 2em;
				cursor: pointer;
				font-size: 0.9em;
				line-height: 1;
			}
			.rb:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.rb.del:hover {
				border-color: #9a2515;
				color: #9a2515;
			}
			.actions {
				display: flex;
				align-items: center;
				gap: 0.75em;
				margin-top: 1.25em;
				flex-wrap: wrap;
			}
			button.primary {
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 8px;
				padding: 0.7em 1.4em;
				font-size: 1em;
				font-weight: 700;
				cursor: pointer;
			}
			button.primary:disabled {
				opacity: 0.6;
				cursor: default;
			}
			button.ghost {
				background: none;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.7em 1.1em;
				cursor: pointer;
				color: rgb(var(--gray-dark));
			}
			.status {
				font-size: 0.85em;
				color: #0d7a3f;
				font-weight: 700;
			}
			.status.err {
				color: #9a2515;
			}
			.privacy {
				margin: 1em 0 0;
				font-size: 0.82em;
				color: rgb(var(--gray-dark));
			}
			.prose h2 {
				margin-top: 1.5em;
			}
			.prose .faq {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.75em 1em;
				margin-bottom: 0.6em;
			}
			.prose .faq summary {
				cursor: pointer;
				font-weight: 700;
				font-size: 0.95em;
			}
			.prose .faq p {
				margin: 0.75em 0 0;
				font-size: 0.92em;
			}
			.recommends {
				background: rgba(var(--gray-light), 40%);
				border-radius: 12px;
				padding: 1.25em 1.5em;
				margin: 2.5em 0;
			}
			.recommends h2 {
				margin-top: 0;
				font-size: 1.6em;
			}
			.recommends .tiny {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin-bottom: 0;
			}
			.back {
				margin-top: 2em;
			}
		</style>
	</body>
</html>
