---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Free Tools for Solopreneurs & Freelancers | Toolbase';
const description =
	'Free, no-sign-up tools for one-person businesses — calculators and decision aids that run instantly in your browser. New tool every week.';

const tools = [
	{
		href: '/tools/freelance-rate-calculator/',
		name: 'Freelance Hourly Rate Calculator',
		blurb:
			'Work out exactly what to charge per hour — after expenses, taxes, time off and the hours you can actually bill.',
		tag: 'Pricing',
		eta: '2 min',
	},
	{
		href: '/tools/contract-vs-salary-calculator/',
		name: 'Contract vs Salary Calculator',
		blurb:
			'Compare a contract or freelance rate against a full-time salary net of tax, benefits and unpaid time off — with a clear verdict and your break-even rate.',
		tag: 'Decision',
		eta: '3 min',
	},
	{
		href: '/tools/project-quote-calculator/',
		name: 'Freelance Project Quote Calculator',
		blurb:
			"Turn your hourly rate into a fixed project price with scope buffer, costs and margin — then test a client's budget and see the real hourly rate it pays.",
		tag: 'Pricing',
		eta: '3 min',
	},
	{
		href: '/tools/rate-increase-calculator/',
		name: 'Rate Increase Calculator',
		blurb:
			'Thinking of raising your rates? See how many clients you can afford to lose and still earn more than you do now — with a full scenario table.',
		tag: 'Pricing',
		eta: '2 min',
	},
	{
		href: '/tools/merge-pdf/',
		name: 'Merge PDF',
		blurb:
			'Combine PDFs and images into one file, reorder them and extract page ranges — 100% in your browser. Your files are never uploaded.',
		tag: 'PDF',
		eta: '1 min',
	},
	{
		href: '/tools/split-pdf/',
		name: 'Split PDF',
		blurb:
			'Split one PDF into multiple files — by custom ranges, every N pages, or one file per page. Downloads as a zip; 100% in your browser.',
		tag: 'PDF',
		eta: '1 min',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="tools-index">
			<header class="page-head">
				<span class="eyebrow">No sign-up · Runs in your browser</span>
				<h1>Free tools for solo businesses</h1>
				<p class="lede">
					Small, fast tools for freelancers and solopreneurs. No sign-up, no upload, nothing
					sent to a server — every calculator runs entirely in your browser. A new one ships
					each week.
				</p>
			</header>

			<ul class="tool-grid">
				{
					tools.map((t) => (
						<li>
							<a href={t.href}>
								<div class="tool-head">
									<span class="tag">{t.tag}</span>
									<span class="eta">{t.eta}</span>
								</div>
								<h2>{t.name}</h2>
								<p>{t.blurb}</p>
								<span class="open">Open tool →</span>
							</a>
						</li>
					))
				}
			</ul>

			<p class="more">More tools landing weekly. Got a request? It probably belongs here.</p>
		</main>
		<Footer />
		<style>
			.tools-index {
				width: var(--max-w-content);
				max-width: calc(100% - 2em);
			}
			.page-head {
				padding: 2em 0 2.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5em;
				max-width: 760px;
			}
			.eyebrow {
				display: inline-block;
				font-size: 0.75em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--accent-dark);
				margin-bottom: 0.75em;
			}
			.page-head h1 {
				font-size: 2.8em;
				margin: 0 0 0.4em;
				line-height: 1.1;
			}
			.lede {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
				margin: 0;
				max-width: 640px;
			}
			.tool-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5em;
			}
			.tool-grid a {
				position: relative;
				display: block;
				background: var(--surface);
				border: 1px solid rgb(var(--gray-light));
				border-radius: var(--radius-md);
				padding: 1.5em 1.6em;
				text-decoration: none;
				color: inherit;
				transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
				height: 100%;
			}
			.tool-grid a:hover {
				transform: translateY(-3px);
				box-shadow: var(--shadow-md);
				border-color: rgba(224, 120, 86, 0.45);
			}
			.tool-head {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.6em;
			}
			.tag {
				display: inline-block;
				font-size: 0.7em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--accent-dark);
				background: var(--accent-soft);
				padding: 0.25em 0.6em;
				border-radius: 999px;
			}
			.eta {
				font-size: 0.75em;
				color: rgb(var(--gray));
				font-weight: 600;
			}
			.tool-grid h2 {
				font-size: 1.3em;
				margin: 0 0 0.5em;
				line-height: 1.25;
				color: rgb(var(--black));
			}
			.tool-grid p {
				font-size: 0.95em;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
				margin: 0 0 0.9em;
			}
			.open {
				display: inline-block;
				font-size: 0.85em;
				color: var(--accent-dark);
				font-weight: 600;
			}
			.more {
				margin-top: 2em;
				font-size: 0.9em;
				color: rgb(var(--gray));
			}
			@media (max-width: 700px) {
				.page-head h1 { font-size: 2em; }
				.tool-grid { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
