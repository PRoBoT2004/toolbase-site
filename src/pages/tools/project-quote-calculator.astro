---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Freelance Project Quote Calculator, Price Any Project (and Know If It’s Worth It) | Toolbase';
const description =
	'Turn your hourly rate into a fixed project quote, with a scope buffer, costs and margin built in. Then paste a client’s budget and see the real hourly rate it pays you, with a clear go / renegotiate / walk-away verdict. Free, instant, no sign-up.';

const faqs = [
	{
		q: 'How do I price a fixed-price freelance project?',
		a: 'Start from your hourly rate (your floor), estimate the hours the project really takes, then add a buffer for the revisions and scope creep that always happen. Add any direct costs you pass through, then a profit margin on top. The result is a fixed quote that still protects your effective hourly rate. This calculator does exactly that.',
	},
	{
		q: 'Why add a scope / revision buffer?',
		a: 'Because fixed-price work almost always runs over. Extra rounds of revisions, "quick" additions and client delays are unpaid unless you priced for them. A 20–30% buffer on your hour estimate keeps a fixed price from quietly turning into a below-minimum-wage job.',
	},
	{
		q: 'What is my "effective hourly rate" on a project?',
		a: 'It is the fixed fee (minus any direct costs) divided by the hours you actually spend, including the buffer. It is the number that tells the truth: a $4,000 project that eats 80 hours pays $50/hour, not whatever the headline implies. If your effective rate falls below your floor, the project is losing you money versus hourly work.',
	},
	{
		q: 'A client gave me a budget, how do I know if it is worth taking?',
		a: 'Put their budget in the optional field. The calculator divides it by your buffered hours to show the real hourly rate it pays, and compares that to your floor: take it, renegotiate, or walk away. It removes the emotion from "this is a big number" by showing what the number actually means per hour.',
	},
	{
		q: 'Should I tell the client my hourly rate?',
		a: 'Usually no. Quote a single fixed price for the outcome. Use your hourly rate privately as the floor this calculator builds from. Clients buy results and price certainty, not a timesheet, and fixed pricing lets you keep the upside when you work efficiently.',
	},
];

const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
});

const appJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Freelance Project Quote Calculator',
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Any (web browser)',
	url: 'https://gettoolbase.org/tools/project-quote-calculator/',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	description: description,
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://gettoolbase.org/tools/' },
		{
			'@type': 'ListItem',
			position: 3,
			name: 'Project Quote Calculator',
			item: 'https://gettoolbase.org/tools/project-quote-calculator/',
		},
	],
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={faqJsonLd} />
		<script type="application/ld+json" is:inline set:html={appJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/tools/">Tools</a> › <span>Project Quote Calculator</span>
			</nav>

			<h1>Freelance Project Quote Calculator</h1>
			<p class="lede">
				Turn your hourly rate into a fixed project price, with the scope buffer, costs and margin most
				freelancers forget. Then drop in a client's budget and see the <em>real</em> hourly rate it pays
				you, with a straight go / renegotiate / walk-away verdict. Runs entirely in your browser.
			</p>

			<section class="calc" aria-label="Project quote calculator">
				<div class="field currency-field">
					<label for="currency">Currency</label>
					<select id="currency">
						<option value="USD">$ USD, US Dollar</option>
						<option value="EUR">€ EUR, Euro</option>
						<option value="GBP">£ GBP, British Pound</option>
						<option value="INR">₹ INR, Indian Rupee</option>
						<option value="CAD">$ CAD, Canadian Dollar</option>
						<option value="AUD">$ AUD, Australian Dollar</option>
					</select>
				</div>

				<div class="calc-grid">
					<div class="inputs">
						<div class="field">
							<label for="rate">Your hourly rate (your floor)</label>
							<input id="rate" type="number" min="0" step="5" inputmode="numeric" value="75" />
							<small>The minimum your time is worth. <a href="/tools/freelance-rate-calculator/">Not sure? Work it out →</a></small>
						</div>
						<div class="field">
							<label for="hours">Estimated hours for the project</label>
							<input id="hours" type="number" min="0" step="1" inputmode="numeric" value="40" />
							<small>Your honest best estimate of the real work.</small>
						</div>
						<div class="field">
							<label for="buffer">Scope / revision buffer (%)</label>
							<input id="buffer" type="number" min="0" max="200" step="5" inputmode="numeric" value="25" />
							<small>Extra hours you always end up giving away. 20–30% is realistic.</small>
						</div>
						<div class="field">
							<label for="costs">Direct project costs</label>
							<input id="costs" type="number" min="0" step="50" inputmode="numeric" value="0" />
							<small>Stock assets, subcontractors, paid tools you pass through.</small>
						</div>
						<div class="field">
							<label for="margin">Profit margin (%)</label>
							<input id="margin" type="number" min="0" max="200" step="5" inputmode="numeric" value="15" />
							<small>On top of covering your time and costs.</small>
						</div>
						<div class="field budget-field">
							<label for="budget">Client's budget (optional)</label>
							<input id="budget" type="number" min="0" step="100" inputmode="numeric" placeholder="e.g. 3000" />
							<small>Fill this to test an offer against your floor.</small>
						</div>
					</div>

					<div class="result">
						<div class="headline">
							<span class="label">Quote this project at</span>
							<span class="rate" id="out-quote">,</span>
						</div>
						<div class="secondary">
							<div>
								<span class="s-label">Effective rate at this quote</span>
								<span class="s-val" id="out-eff-quote">,</span>
							</div>
							<div>
								<span class="s-label">Buffered hours</span>
								<span class="s-val" id="out-hours">,</span>
							</div>
						</div>

						<div class="verdict" id="verdict">
							<span class="v-line" id="v-line">,</span>
							<span class="v-sub" id="v-sub"></span>
						</div>

						<details class="breakdown">
							<summary>Show the math</summary>
							<table>
								<tbody id="breakdown-body"></tbody>
							</table>
						</details>
					</div>
				</div>
				<p class="disclaimer">
					A pricing floor, not a ceiling, value-based pricing can go far higher. Estimate only; your
					market and the client's perceived value set the final number.
				</p>
				<p class="cross">Related: <a href="/tools/contract-vs-salary-calculator/">Contract vs salary calculator</a> · <a href="/tools/freelance-rate-calculator/">Freelance rate calculator</a></p>
			</section>

			<div class="prose">
				<h2>How to price a freelance project (without losing money)</h2>
				<p>
					Most freelancers price a project by feel, they picture a number that sounds reasonable to
					the client and hope it works out. It usually doesn't, because the number ignores revisions,
					admin and the hours the project quietly balloons into. Price it from the bottom up instead:
				</p>
				<ol>
					<li><strong>Start from your hourly floor.</strong> The minimum your time is worth, taxes, expenses and unpaid time already baked in.</li>
					<li><strong>Estimate the real hours,</strong> then add a buffer for the revisions and scope creep that are guaranteed, not hypothetical.</li>
					<li><strong>Add direct costs</strong> you'll pass through, stock, subcontractors, paid tools.</li>
					<li><strong>Add a margin</strong> so the project builds your business, not just covers it.</li>
					<li><strong>Check the effective hourly rate.</strong> If a client's budget drags it below your floor, you now know, before you say yes.</li>
				</ol>

				<h2>Hourly vs fixed vs value pricing</h2>
				<p>
					<strong>Hourly</strong> is safest for open-ended work but caps your upside and punishes you for
					getting faster. <strong>Fixed price</strong>, what this calculator produces, gives the client
					certainty and lets you keep the gains from working efficiently, as long as you buffered for
					scope. <strong>Value pricing</strong> ignores hours entirely and charges a slice of the outcome's
					worth; it pays the most but needs a clear, measurable result. Use this tool's fixed price as
					your floor, then price up toward value when the project clearly justifies it.
				</p>

				<h2>Frequently asked questions</h2>
				{
					faqs.map((f) => (
						<details class="faq">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>

			<!--
				MONETIZATION: outbound links are affiliate-ready.
				Swap each href for the tracked affiliate URL on approval and change
				rel to "sponsored noopener". Until then: plain rel="nofollow noopener"
				links to the real homepages, nothing fake is shipped.
			-->
			<aside class="recommends">
				<h2>Turn the quote into a signed project</h2>
				<p>What freelancers use to send the proposal and get paid:</p>
				<ul>
					<li><a href="https://www.bonsai.com/" rel="nofollow noopener" target="_blank">Bonsai</a>, proposals, contracts and invoicing in one flow.</li>
					<li><a href="https://www.freshbooks.com/" rel="nofollow noopener" target="_blank">FreshBooks</a>, turn the accepted quote into an invoice and track it.</li>
					<li><a href="https://www.getharvest.com/" rel="nofollow noopener" target="_blank">Harvest</a>, track actual hours so your next estimate is sharper.</li>
				</ul>
				<p class="tiny">We only list tools we'd use ourselves. Some links may become affiliate links, it never changes what we recommend or costs you anything.</p>
			</aside>

			<p class="back"><a href="/tools/">← All Toolbase tools</a></p>
		</main>
		<Footer />

		<script>
			const ids = ['currency', 'rate', 'hours', 'buffer', 'costs', 'margin', 'budget'];
			const DEFAULTS = {
				currency: 'USD',
				rate: 75,
				hours: 40,
				buffer: 25,
				costs: 0,
				margin: 15,
				budget: '',
			};
			const KEY = 'tb-project-quote';

			const $ = (id) => document.getElementById(id);
			const num = (id) => {
				const v = parseFloat($(id).value);
				return isNaN(v) ? 0 : v;
			};
			const has = (id) => $(id).value.trim() !== '' && !isNaN(parseFloat($(id).value));

			function money(value, currency) {
				try {
					return new Intl.NumberFormat(undefined, {
						style: 'currency',
						currency,
						maximumFractionDigits: 0,
					}).format(value);
				} catch (e) {
					return Math.round(value).toString();
				}
			}
			function money2(value, currency) {
				try {
					return new Intl.NumberFormat(undefined, {
						style: 'currency',
						currency,
						maximumFractionDigits: value < 100 ? 2 : 0,
					}).format(value);
				} catch (e) {
					return value.toFixed(2);
				}
			}

			function compute() {
				const currency = $('currency').value;
				const rate = num('rate');
				const hours = num('hours');
				const buffer = num('buffer') / 100;
				const costs = num('costs');
				const margin = num('margin') / 100;

				const bufHours = hours * (1 + buffer);
				const labor = bufHours * rate;
				const beforeMargin = labor + costs;
				const quote = beforeMargin * (1 + margin);
				const effAtQuote = bufHours > 0 ? (quote - costs) / bufHours : 0;
				const valid = bufHours > 0 && rate > 0;

				$('out-quote').textContent = valid ? money(quote, currency) : ',';
				$('out-eff-quote').textContent = valid ? money2(effAtQuote, currency) + ' / hr' : ',';
				$('out-hours').textContent = valid ? bufHours.toLocaleString() + ' hrs' : ',';

				const v = $('verdict');
				const vLine = $('v-line');
				const vSub = $('v-sub');
				v.classList.remove('win', 'lose', 'warn', 'neutral');

				if (has('budget') && valid) {
					const budget = num('budget');
					const effAtBudget = (budget - costs) / bufHours;
					if (effAtBudget >= rate) {
						v.classList.add('win');
						vLine.textContent = 'Worth it, pays ' + money2(effAtBudget, currency) + ' / hr';
						vSub.textContent = 'Their budget clears your ' + money2(rate, currency) + ' floor. Take it.';
					} else if (effAtBudget >= rate * 0.85) {
						v.classList.add('warn');
						vLine.textContent = 'Thin, pays ' + money2(effAtBudget, currency) + ' / hr';
						vSub.textContent =
							'Just under your ' + money2(rate, currency) + ' floor. Renegotiate or trim scope.';
					} else {
						v.classList.add('lose');
						vLine.textContent = 'Walk away, pays ' + money2(effAtBudget, currency) + ' / hr';
						vSub.textContent =
							'Well below your ' + money2(rate, currency) + ' floor. This loses you money.';
					}
				} else {
					v.classList.add('neutral');
					vLine.textContent = valid
						? 'This quote pays you ' + money2(effAtQuote, currency) + ' / hr'
						: 'Enter your numbers';
					vSub.textContent = valid ? 'Add a client budget above to test their offer.' : '';
				}

				const rows = [
					[`Buffered hours (${hours} + ${(buffer * 100).toFixed(0)}%)`, valid ? bufHours.toLocaleString() + ' hrs' : ','],
					[`Labour (${bufHours.toLocaleString()} × ${money2(rate, currency)})`, money(labor, currency)],
					['+ Direct costs', money(costs, currency)],
					['= Before margin', money(beforeMargin, currency)],
					[`+ ${(margin * 100).toFixed(0)}% margin`, '+' + money(beforeMargin * margin, currency)],
					['= Recommended quote', money(quote, currency)],
				];
				$('breakdown-body').innerHTML = rows
					.map((r) => `<tr><td>${r[0]}</td><td class="amt">${r[1]}</td></tr>`)
					.join('');

				save();
			}

			function save() {
				const data = {};
				ids.forEach((id) => (data[id] = $(id).value));
				try {
					localStorage.setItem(KEY, JSON.stringify(data));
				} catch (e) {}
			}
			function load() {
				try {
					const raw = localStorage.getItem(KEY);
					if (!raw) return;
					const data = JSON.parse(raw);
					ids.forEach((id) => {
						if (data[id] !== undefined) $(id).value = data[id];
					});
				} catch (e) {}
			}

			ids.forEach((id) => {
				$(id).addEventListener('input', compute);
				$(id).addEventListener('change', compute);
				$(id).addEventListener('wheel', (e) => {
					if (document.activeElement === e.target) e.target.blur();
				});
			});

			load();
			compute();
		</script>

		<style>
			.crumbs {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
			}
			.crumbs a {
				color: rgb(var(--gray));
			}
			.lede {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
			}
			.calc {
				margin: 2em 0 3em;
			}
			.currency-field {
				max-width: 280px;
				margin-bottom: 1.25em;
			}
			.calc-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5em;
			}
			.inputs {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.25em;
			}
			.field {
				margin-bottom: 1em;
			}
			.field label {
				display: block;
				font-weight: 700;
				font-size: 0.85em;
				margin-bottom: 0.25em;
			}
			.field input,
			.field select {
				width: 100%;
				padding: 0.55em 0.6em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: #fff;
				box-sizing: border-box;
			}
			.field input:focus,
			.field select:focus {
				outline: 2px solid var(--accent);
				border-color: var(--accent);
			}
			.budget-field {
				border-top: 1px dashed rgb(var(--gray-light));
				padding-top: 1em;
				margin-bottom: 0;
			}
			.field small {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.72em;
				margin-top: 0.25em;
				line-height: 1.4;
			}
			.result {
				background: rgb(var(--gray-dark));
				color: #fff;
				border-radius: var(--radius-md);
				padding: 1.5em;
				position: sticky;
				top: 80px;
				align-self: start;
				box-shadow: var(--shadow-md);
			}
			.headline {
				text-align: center;
				padding-bottom: 1em;
				border-bottom: 1px solid rgba(255, 255, 255, 0.15);
			}
			.headline .label {
				display: block;
				font-size: 0.8em;
				opacity: 0.7;
			}
			.headline .rate {
				display: block;
				font-size: 2.8em;
				font-weight: 700;
				line-height: 1.1;
				color: #fff;
			}
			.secondary {
				display: grid;
				gap: 0.6em;
				margin: 1em 0;
			}
			.secondary > div {
				display: flex;
				justify-content: space-between;
				font-size: 0.85em;
			}
			.secondary .s-label {
				opacity: 0.75;
			}
			.secondary .s-val {
				font-weight: 700;
			}
			.verdict {
				border-radius: 8px;
				padding: 0.9em;
				text-align: center;
				margin: 0.5em 0 0.75em;
			}
			.verdict.neutral {
				background: rgba(255, 255, 255, 0.1);
			}
			.verdict.win {
				background: #0d7a3f;
			}
			.verdict.warn {
				background: #8a6d00;
			}
			.verdict.lose {
				background: #9a2515;
			}
			.verdict .v-line {
				display: block;
				font-size: 1.15em;
				font-weight: 700;
				line-height: 1.25;
			}
			.verdict .v-sub {
				display: block;
				font-size: 0.78em;
				opacity: 0.9;
				margin-top: 0.25em;
			}
			.breakdown {
				font-size: 0.8em;
			}
			.breakdown summary {
				cursor: pointer;
				opacity: 0.85;
			}
			.breakdown table {
				margin-top: 0.75em;
				border-collapse: collapse;
			}
			.breakdown td {
				padding: 0.35em 0;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				vertical-align: top;
			}
			.breakdown td.amt {
				text-align: right;
				font-weight: 700;
				white-space: nowrap;
				padding-left: 1em;
			}
			.disclaimer {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin: 1em 0 0;
				line-height: 1.5;
			}
			.cross {
				font-size: 0.9em;
				margin: 0.5em 0 0;
			}
			.prose h2 {
				margin-top: 1.5em;
			}
			.prose .faq {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.75em 1em;
				margin-bottom: 0.6em;
			}
			.prose .faq summary {
				cursor: pointer;
				font-weight: 700;
				font-size: 0.95em;
			}
			.prose .faq p {
				margin: 0.75em 0 0;
				font-size: 0.92em;
			}
			.recommends {
				background: rgba(var(--gray-light), 40%);
				border-radius: 12px;
				padding: 1.25em 1.5em;
				margin: 2.5em 0;
			}
			.recommends h2 {
				margin-top: 0;
				font-size: 1.6em;
			}
			.recommends .tiny {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin-bottom: 0;
			}
			.back {
				margin-top: 2em;
			}
			@media (max-width: 720px) {
				.calc-grid {
					grid-template-columns: 1fr;
				}
				.result {
					position: static;
				}
			}
		</style>
	</body>
</html>
