---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Contract vs Salary Calculator, Is Freelancing Actually Worth It? | Toolbase';
const description =
	'Compare a contract or freelance rate against a full-time salary properly, net of expenses, self-employment tax, unpaid time off and the benefits a job hides. Get a clear verdict and your break-even rate. Free, instant, no sign-up.';

const faqs = [
	{
		q: 'Is contracting really better paid than a salaried job?',
		a: 'Often yes on paper, but the headline rate is misleading. A contractor loses the employer-paid taxes, pension match, health cover, paid holiday and sick leave that a salary quietly includes, and pays for their own tools and downtime. Once you net all of that out, which this calculator does, the gap is usually much smaller than the raw rate suggests, and sometimes the salary wins.',
	},
	{
		q: 'How do I compare a day rate or hourly rate to an annual salary?',
		a: 'You cannot just multiply the rate by 2,080 hours. Multiply your rate by the hours (or days) you can actually bill per week, then by the weeks you actually work (not 52, subtract your unpaid time off). Then subtract business expenses and the extra self-employment tax you now carry. Compare that net figure to the salary plus the cash value of its benefits. This tool runs that whole calculation for you.',
	},
	{
		q: 'What benefits should I count on the salary side?',
		a: 'Anything the employer pays that you would have to fund yourself as a contractor: pension or 401(k) match, health insurance, paid holiday and sick days, life/disability cover, training budget, and the employer half of payroll taxes. Add up the annual cash value and put it in the "employer benefits" field, leaving it at zero will make a salary look worse than it really is.',
	},
	{
		q: 'What is a break-even rate?',
		a: 'It is the hourly (or daily) rate at which contracting leaves you exactly as well off as the salary, after expenses and self-employment tax. Charge above it and contracting wins; below it and the salary wins. It is the single most useful number when deciding whether a contract offer is worth leaving a job for.',
	},
	{
		q: 'Does this account for income tax?',
		a: 'It compares structural value before your personal income tax, because income tax depends on your country, state and bracket and applies to both options. It does include the extra self-employment / employer-side tax that is unique to contracting, since that is the main structural difference. For an exact take-home figure, run the result through a tax calculator for your region.',
	},
];

const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
});

const appJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Contract vs Salary Calculator',
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Any (web browser)',
	url: 'https://gettoolbase.org/tools/contract-vs-salary-calculator/',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	description: description,
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://gettoolbase.org/tools/' },
		{
			'@type': 'ListItem',
			position: 3,
			name: 'Contract vs Salary Calculator',
			item: 'https://gettoolbase.org/tools/contract-vs-salary-calculator/',
		},
	],
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={faqJsonLd} />
		<script type="application/ld+json" is:inline set:html={appJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/tools/">Tools</a> › <span>Contract vs Salary Calculator</span>
			</nav>

			<h1>Contract vs Salary Calculator</h1>
			<p class="lede">
				A contract rate that looks huge next to a salary often isn't, once you subtract the taxes,
				benefits and paid time off a job quietly includes. This compares the two <em>properly</em>, 				net of all of it, and tells you which actually leaves you better off, plus the exact rate you'd
				need to break even. Runs entirely in your browser.
			</p>

			<section class="calc" aria-label="Contract vs salary calculator">
				<div class="field currency-field">
					<label for="currency">Currency</label>
					<select id="currency">
						<option value="USD">$ USD, US Dollar</option>
						<option value="EUR">€ EUR, Euro</option>
						<option value="GBP">£ GBP, British Pound</option>
						<option value="INR">₹ INR, Indian Rupee</option>
						<option value="CAD">$ CAD, Canadian Dollar</option>
						<option value="AUD">$ AUD, Australian Dollar</option>
					</select>
				</div>

				<div class="calc-grid">
					<div class="col salary-col">
						<h2 class="col-head">The salaried job</h2>
						<div class="field">
							<label for="salary">Gross annual salary</label>
							<input id="salary" type="number" min="0" step="1000" inputmode="numeric" value="70000" />
						</div>
						<div class="field">
							<label for="benefits">Employer benefits (annual cash value)</label>
							<input id="benefits" type="number" min="0" step="500" inputmode="numeric" value="9000" />
							<small>Pension match, health cover, paid leave, training, employer payroll tax.</small>
						</div>
					</div>

					<div class="col contract-col">
						<h2 class="col-head">The contract / freelance gig</h2>
						<div class="field">
							<label for="rate">Your rate</label>
							<div class="rate-row">
								<input id="rate" type="number" min="0" step="1" inputmode="numeric" value="65" />
								<select id="rateType">
									<option value="hour">per hour</option>
									<option value="day">per day</option>
								</select>
							</div>
						</div>
						<div class="field">
							<label for="perWeek"><span id="perWeekLabel">Billable hours per week</span></label>
							<input id="perWeek" type="number" min="1" step="1" inputmode="numeric" value="40" />
							<small>Hours (or days) a client actually pays for.</small>
						</div>
						<div class="field">
							<label for="weeks">Working weeks per year</label>
							<input id="weeks" type="number" min="1" max="52" step="1" inputmode="numeric" value="46" />
							<small>52 minus your unpaid holiday, sick days and gaps.</small>
						</div>
						<div class="field">
							<label for="expenses">Annual business expenses</label>
							<input id="expenses" type="number" min="0" step="500" inputmode="numeric" value="4000" />
						</div>
						<div class="field">
							<label for="tax">Extra self-employment tax (%)</label>
							<input id="tax" type="number" min="0" max="60" step="0.5" inputmode="decimal" value="8" />
							<small>The employer-side tax you now cover yourself.</small>
						</div>
					</div>
				</div>

				<div class="verdict" id="verdict" aria-live="polite">
					<span class="v-line" id="v-line">,</span>
					<span class="v-sub" id="v-sub"></span>
				</div>

				<div class="compare">
					<div class="compare-card">
						<span class="c-label">Salary, total value</span>
						<span class="c-val" id="out-salary">,</span>
						<span class="c-note">salary + benefits</span>
					</div>
					<div class="compare-card">
						<span class="c-label">Contract, net value</span>
						<span class="c-val" id="out-contract">,</span>
						<span class="c-note">after expenses &amp; SE tax</span>
					</div>
					<div class="compare-card highlight">
						<span class="c-label">Break-even rate</span>
						<span class="c-val" id="out-breakeven">,</span>
						<span class="c-note" id="out-breakeven-note">to match the salary</span>
					</div>
				</div>

				<details class="breakdown">
					<summary>Show the math</summary>
					<table>
						<tbody id="breakdown-body"></tbody>
					</table>
				</details>
				<p class="disclaimer">
					Compares structural value before your personal income tax (which applies to both options and
					depends on your region). Includes the extra self-employment tax unique to contracting. An
					estimate to inform the decision, not financial advice.
				</p>
				<p class="cross">
					Not sure what rate to put in?
					<a href="/tools/freelance-rate-calculator/">Work out your minimum freelance rate first →</a>
				</p>
			</section>

			<div class="prose">
				<h2>How to actually compare a contract rate to a salary</h2>
				<p>
					The reason so many people take a contract and end up feeling poorer is that they compared the
					wrong numbers. A $65/hour rate <em>sounds</em> like $135,000 a year (65 × 2,080). It isn't.
					Here's the comparison that holds up:
				</p>
				<ol>
					<li><strong>Build the salary's true value.</strong> Take the gross salary and add the cash value of everything the employer pays on top, pension match, health insurance, paid holiday and sick days, the employer half of payroll taxes. That's the number contracting has to beat.</li>
					<li><strong>Build the contract's real income.</strong> Rate × hours (or days) you can <em>bill</em> per week × the weeks you actually work. Not 52, contractors don't get paid holidays.</li>
					<li><strong>Subtract what contracting costs.</strong> Business expenses, plus the extra self-employment tax you now shoulder that an employer used to split with you.</li>
					<li><strong>Compare the two net figures</strong>, and look at the break-even rate to see how much headroom (or shortfall) you actually have.</li>
				</ol>

				<h2>Why a contract rate has to be much higher than a salary</h2>
				<p>
					A salaried employee is paid for roughly 2,080 hours a year and never works all of them on
					billable output, yet still gets paid for holidays, sick days and the gaps between projects.
					A contractor is paid only for hours billed, funds their own taxes and tools, and earns nothing
					while on holiday or between clients. To stand still against a salary, a contractor typically
					needs a headline rate <strong>40–80% higher</strong> than the salary-per-hour figure. Anything
					less and the "raise" is an illusion.
				</p>

				<h2>Frequently asked questions</h2>
				{
					faqs.map((f) => (
						<details class="faq">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>

			<!--
				MONETIZATION: outbound links are affiliate-ready.
				Swap each href for the tracked affiliate URL on approval and change
				rel to "sponsored noopener". Until then: plain rel="nofollow noopener"
				links to the real homepages, nothing fake is shipped.
			-->
			<aside class="recommends">
				<h2>If you decide to go contract</h2>
				<p>What you'll want set up before your first invoice goes out:</p>
				<ul>
					<li><a href="https://www.freshbooks.com/" rel="nofollow noopener" target="_blank">FreshBooks</a>, invoicing &amp; expense tracking for the self-employed.</li>
					<li><a href="https://www.bonsai.com/" rel="nofollow noopener" target="_blank">Bonsai</a>, contracts, proposals and accounting in one place.</li>
					<li><a href="https://toggl.com/track/" rel="nofollow noopener" target="_blank">Toggl Track</a>, prove your real billable hours so this comparison stays honest.</li>
				</ul>
				<p class="tiny">We only list tools we'd use ourselves. Some links may become affiliate links, it never changes what we recommend or costs you anything.</p>
			</aside>

			<p class="back"><a href="/tools/">← All Toolbase tools</a></p>
		</main>
		<Footer />

		<script>
			const ids = ['currency', 'salary', 'benefits', 'rate', 'rateType', 'perWeek', 'weeks', 'expenses', 'tax'];
			const DEFAULTS = {
				currency: 'USD',
				salary: 70000,
				benefits: 9000,
				rate: 65,
				rateType: 'hour',
				perWeek: 40,
				weeks: 46,
				expenses: 4000,
				tax: 8,
			};
			const KEY = 'tb-contract-vs-salary';

			const $ = (id) => document.getElementById(id);
			const num = (id) => {
				const v = parseFloat($(id).value);
				return isNaN(v) ? 0 : v;
			};

			function money(value, currency) {
				try {
					return new Intl.NumberFormat(undefined, {
						style: 'currency',
						currency,
						maximumFractionDigits: 0,
					}).format(value);
				} catch (e) {
					return Math.round(value).toString();
				}
			}
			function money2(value, currency) {
				try {
					return new Intl.NumberFormat(undefined, {
						style: 'currency',
						currency,
						maximumFractionDigits: value < 100 ? 2 : 0,
					}).format(value);
				} catch (e) {
					return value.toFixed(2);
				}
			}

			function compute() {
				const currency = $('currency').value;
				const salary = num('salary');
				const benefits = num('benefits');
				const rate = num('rate');
				const unit = $('rateType').value; // 'hour' | 'day'
				const perWeek = num('perWeek');
				const weeks = num('weeks');
				const expenses = num('expenses');
				const tax = Math.min(num('tax'), 60) / 100;

				$('perWeekLabel').textContent =
					unit === 'day' ? 'Billable days per week' : 'Billable hours per week';

				const salaryValue = salary + benefits;
				const unitsPerYear = perWeek * weeks; // hours/year or days/year
				const grossContract = rate * unitsPerYear;
				const contractValue = grossContract * (1 - tax) - expenses;

				const diff = contractValue - salaryValue;
				const pct = salaryValue > 0 ? (diff / salaryValue) * 100 : 0;
				const unitWord = unit === 'day' ? 'day' : 'hour';

				// break-even rate: rate where contractValue == salaryValue
				const denom = unitsPerYear * (1 - tax);
				const breakeven = denom > 0 ? (salaryValue + expenses) / denom : 0;

				const valid = unitsPerYear > 0 && (salary > 0 || benefits > 0 || rate > 0);

				$('out-salary').textContent = valid ? money(salaryValue, currency) : ',';
				$('out-contract').textContent = valid ? money(contractValue, currency) : ',';
				$('out-breakeven').textContent = valid ? money2(breakeven, currency) + ' / ' + unitWord : ',';

				const v = $('verdict');
				const vLine = $('v-line');
				const vSub = $('v-sub');
				v.classList.remove('win', 'lose', 'tie');
				if (!valid) {
					vLine.textContent = 'Enter your numbers to see the verdict';
					vSub.textContent = '';
				} else if (Math.abs(diff) < salaryValue * 0.02) {
					v.classList.add('tie');
					vLine.textContent = 'It’s roughly a wash';
					vSub.textContent = 'The two come out within ~2% of each other before income tax.';
				} else if (diff > 0) {
					v.classList.add('win');
					vLine.textContent = 'Contracting leaves you ' + money(Math.abs(diff), currency) + ' better off';
					vSub.textContent =
						'About ' + Math.abs(pct).toFixed(0) + '% more per year than the salary, before income tax.';
				} else {
					v.classList.add('lose');
					vLine.textContent = 'The salary leaves you ' + money(Math.abs(diff), currency) + ' better off';
					vSub.textContent =
						'Contracting is about ' +
						Math.abs(pct).toFixed(0) +
						'% behind. You’d need a higher rate.';
				}

				const rows = [
					['Gross salary', money(salary, currency)],
					['+ Employer benefits', money(benefits, currency)],
					['= Salary total value', money(salaryValue, currency)],
					['', ''],
					[
						`Contract gross (${money2(rate, currency)} × ${perWeek} ${unit === 'day' ? 'days' : 'hrs'} × ${weeks} wks)`,
						money(grossContract, currency),
					],
					[`− ${(tax * 100).toFixed(1)}% self-employment tax`, '−' + money(grossContract * tax, currency)],
					['− Business expenses', '−' + money(expenses, currency)],
					['= Contract net value', money(contractValue, currency)],
					['', ''],
					['Break-even rate to match salary', valid ? money2(breakeven, currency) + ' / ' + unitWord : ','],
				];
				$('breakdown-body').innerHTML = rows
					.map((r) =>
						r[0] === '' && r[1] === ''
							? '<tr class="spacer"><td colspan="2"></td></tr>'
							: `<tr><td>${r[0]}</td><td class="amt">${r[1]}</td></tr>`
					)
					.join('');

				save();
			}

			function save() {
				const data = {};
				ids.forEach((id) => (data[id] = $(id).value));
				try {
					localStorage.setItem(KEY, JSON.stringify(data));
				} catch (e) {}
			}
			function load() {
				try {
					const raw = localStorage.getItem(KEY);
					if (!raw) return;
					const data = JSON.parse(raw);
					ids.forEach((id) => {
						if (data[id] !== undefined && data[id] !== '') $(id).value = data[id];
					});
				} catch (e) {}
			}

			ids.forEach((id) => {
				$(id).addEventListener('input', compute);
				$(id).addEventListener('change', compute);
				$(id).addEventListener('wheel', (e) => {
					if (document.activeElement === e.target) e.target.blur();
				});
			});
			$('reset') && $('reset').addEventListener('click', () => {
				ids.forEach((id) => ($(id).value = DEFAULTS[id]));
				compute();
			});

			load();
			compute();
		</script>

		<style>
			.crumbs {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
			}
			.crumbs a {
				color: rgb(var(--gray));
			}
			.lede {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
			}
			.calc {
				margin: 2em 0 3em;
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.5em;
			}
			.currency-field {
				max-width: 280px;
				margin-bottom: 1.25em;
			}
			.calc-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5em;
			}
			.col {
				border-radius: 10px;
				padding: 1.1em;
			}
			.salary-col {
				background: rgba(var(--gray-light), 45%);
			}
			.contract-col {
				background: rgba(224, 120, 86, 0.06);
			}
			.col-head {
				font-size: 1.1em;
				margin: 0 0 0.8em;
			}
			.field {
				margin-bottom: 0.9em;
			}
			.field label {
				display: block;
				font-weight: 700;
				font-size: 0.85em;
				margin-bottom: 0.25em;
			}
			.field input,
			.field select {
				width: 100%;
				padding: 0.55em 0.6em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: #fff;
				box-sizing: border-box;
			}
			.rate-row {
				display: flex;
				gap: 0.5em;
			}
			.rate-row input {
				flex: 2;
			}
			.rate-row select {
				flex: 1;
			}
			.field input:focus,
			.field select:focus {
				outline: 2px solid var(--accent);
				border-color: var(--accent);
			}
			.field small {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.72em;
				margin-top: 0.25em;
				line-height: 1.4;
			}
			.verdict {
				text-align: center;
				border-radius: 10px;
				padding: 1.1em;
				margin: 1.5em 0 1em;
				background: rgb(var(--gray-dark));
				color: #fff;
			}
			.verdict.win {
				background: #0d7a3f;
			}
			.verdict.lose {
				background: #9a2515;
			}
			.verdict.tie {
				background: #8a6d00;
			}
			.verdict .v-line {
				display: block;
				font-size: 1.5em;
				font-weight: 700;
				line-height: 1.25;
			}
			.verdict .v-sub {
				display: block;
				font-size: 0.85em;
				opacity: 0.85;
				margin-top: 0.3em;
			}
			.compare {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.75em;
			}
			.compare-card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				padding: 0.9em;
				text-align: center;
			}
			.compare-card.highlight {
				border-color: var(--accent);
				background: rgba(224, 120, 86, 0.05);
			}
			.compare-card .c-label {
				display: block;
				font-size: 0.75em;
				color: rgb(var(--gray));
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.03em;
			}
			.compare-card .c-val {
				display: block;
				font-size: 1.5em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0.15em 0;
				line-height: 1.1;
			}
			.compare-card .c-note {
				display: block;
				font-size: 0.72em;
				color: rgb(var(--gray));
			}
			.breakdown {
				font-size: 0.85em;
				margin-top: 1.25em;
			}
			.breakdown summary {
				cursor: pointer;
				color: rgb(var(--gray-dark));
			}
			.breakdown table {
				margin-top: 0.75em;
				border-collapse: collapse;
			}
			.breakdown td {
				padding: 0.35em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				vertical-align: top;
			}
			.breakdown tr.spacer td {
				border: none;
				padding: 0.2em 0;
			}
			.breakdown td.amt {
				text-align: right;
				font-weight: 700;
				white-space: nowrap;
				padding-left: 1em;
			}
			.disclaimer {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin: 1em 0 0;
				line-height: 1.5;
			}
			.cross {
				font-size: 0.9em;
				margin: 0.75em 0 0;
			}
			.prose h2 {
				margin-top: 1.5em;
			}
			.prose .faq {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.75em 1em;
				margin-bottom: 0.6em;
			}
			.prose .faq summary {
				cursor: pointer;
				font-weight: 700;
				font-size: 0.95em;
			}
			.prose .faq p {
				margin: 0.75em 0 0;
				font-size: 0.92em;
			}
			.recommends {
				background: rgba(var(--gray-light), 40%);
				border-radius: 12px;
				padding: 1.25em 1.5em;
				margin: 2.5em 0;
			}
			.recommends h2 {
				margin-top: 0;
				font-size: 1.6em;
			}
			.recommends .tiny {
				font-size: 0.72em;
				color: rgb(var(--gray));
