---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Rotate PDF Free — Fix Sideways Pages in Your Browser | Toolbase';
const description =
	'Rotate PDF pages 90°, 180° or 270° — all pages or just specific ones — and download the fixed file. Runs entirely in your browser; your file is never uploaded. Free, unlimited, no sign-up.';

const faqs = [
	{
		q: 'Is my PDF uploaded to a server?',
		a: 'No. The rotation happens inside your browser on your own device. Your PDF is never sent over the internet or stored anywhere, so it is safe for confidential documents and works even offline once the page has loaded.',
	},
	{
		q: 'How do I rotate only some pages of a PDF?',
		a: 'Choose "Specific pages" and enter a range like 1, 3-5. Only those pages are rotated; the rest are left exactly as they were. Useful when a scanner flipped just a few pages.',
	},
	{
		q: 'Does the rotation stick when I open the file elsewhere?',
		a: 'Yes. This sets the actual page rotation in the PDF itself, so the orientation is permanent and shows correctly in any PDF reader, not just a temporary on-screen view.',
	},
	{
		q: 'Will rotating reduce quality?',
		a: 'No. Rotation only changes a page’s orientation flag — the underlying text and images are untouched, so there is zero quality loss and the file size barely changes.',
	},
	{
		q: 'Is there a size or usage limit?',
		a: 'No artificial limit — no signup, no daily cap, no watermark. Everything runs locally, so the only real ceiling is your device’s memory.',
	},
];

const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
});
const appJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Rotate PDF',
	applicationCategory: 'UtilitiesApplication',
	operatingSystem: 'Any (web browser)',
	url: 'https://gettoolbase.org/tools/rotate-pdf/',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	description: description,
});
const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://gettoolbase.org/tools/' },
		{ '@type': 'ListItem', position: 3, name: 'Rotate PDF', item: 'https://gettoolbase.org/tools/rotate-pdf/' },
	],
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={faqJsonLd} />
		<script type="application/ld+json" is:inline set:html={appJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/tools/">Tools</a> › <span>Rotate PDF</span>
			</nav>

			<h1>Rotate PDF</h1>
			<p class="lede">
				Fix sideways or upside-down pages — rotate the whole PDF or just specific pages, then download
				the corrected file. <strong>Everything happens in your browser:</strong> your file is never
				uploaded, never sent anywhere, never stored. Free, unlimited, no sign-up.
			</p>

			<section class="app" aria-label="Rotate PDF tool">
				<div id="drop" class="drop" tabindex="0" role="button" aria-label="Add a PDF file">
					<p class="drop-big">Drop a PDF here</p>
					<p class="drop-sub">or <span class="link">browse your device</span></p>
					<input id="file-input" type="file" accept="application/pdf" hidden />
				</div>

				<div id="loaded" class="loaded" hidden>
					<div class="file-row">
						<span class="badge pdf">PDF</span>
						<span class="meta"><span class="fname" id="fname"></span><span class="fsub" id="fsub"></span></span>
						<button id="change-btn" type="button" class="rb" aria-label="Choose a different file">✕</button>
					</div>

					<fieldset class="group">
						<legend>Rotation</legend>
						<div class="seg" role="radiogroup" aria-label="Rotation amount">
							<label><input type="radio" name="deg" value="90" checked /> <span>90° ↻</span></label>
							<label><input type="radio" name="deg" value="180" /> <span>180° ⤡</span></label>
							<label><input type="radio" name="deg" value="270" /> <span>90° ↺</span></label>
						</div>
					</fieldset>

					<fieldset class="group">
						<legend>Apply to</legend>
						<label class="mode"><input type="radio" name="scope" value="all" checked /> <span>All pages</span></label>
						<label class="mode"><input type="radio" name="scope" value="some" /> <span>Specific pages</span></label>
						<div class="mode-input" id="pages-input" hidden>
							<input id="pages" type="text" placeholder="e.g. 1, 3-5" />
						</div>
					</fieldset>

					<div class="actions">
						<button id="rotate-btn" type="button" class="primary">Rotate &amp; Download</button>
						<span id="status" class="status" aria-live="polite"></span>
					</div>
				</div>

				<p class="privacy">🔒 100% private — processed locally in your browser. Nothing is uploaded.</p>
			</section>

			<div class="prose">
				<h2>How to rotate a PDF in your browser</h2>
				<ol>
					<li><strong>Add your PDF.</strong> Drop it in or browse — it stays on your device.</li>
					<li><strong>Pick the rotation</strong> — 90° either way, or 180° to flip.</li>
					<li><strong>Choose all pages or specific ones</strong> like <code>1, 3-5</code>.</li>
					<li><strong>Rotate &amp; download</strong> the corrected PDF — no upload.</li>
				</ol>

				<h2>Why rotate PDFs locally?</h2>
				<p>
					Scanners and phone cameras constantly produce sideways pages. Uploading those to a random
					website is a privacy risk, especially for documents. This tool rewrites the orientation flag
					inside the PDF on your own device — permanent, zero quality loss, no upload. Need to do more?
					<a href="/tools/merge-pdf/">Merge</a>, <a href="/tools/split-pdf/">split</a> and
					<a href="/tools/jpg-to-pdf/">convert images</a> the same private way.
				</p>

				<h2>Frequently asked questions</h2>
				{
					faqs.map((f) => (
						<details class="faq">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>

			<aside class="recommends">
				<h2>More PDF tools</h2>
				<ul>
					<li><a href="/tools/merge-pdf/">Merge PDF</a> — combine files into one.</li>
					<li><a href="/tools/split-pdf/">Split PDF</a> — break a PDF into multiple files.</li>
					<li><a href="/tools/jpg-to-pdf/">JPG to PDF</a> — convert images to PDF.</li>
				</ul>
			</aside>

			<p class="back"><a href="/tools/">← All Toolbase tools</a></p>
		</main>
		<Footer />

		<script>
			let _pdfLibPromise = null;
			function loadPdfLib() {
				if (!_pdfLibPromise) _pdfLibPromise = import('pdf-lib');
				return _pdfLibPromise;
			}

			const $ = (id) => document.getElementById(id);
			const drop = $('drop');
			const input = $('file-input');
			const loaded = $('loaded');
			const statusEl = $('status');
			let current = null; // { file, bytes, total, base }

			function fmtSize(b) {
				if (b < 1024) return b + ' B';
				if (b < 1024 * 1024) return (b / 1024).toFixed(0) + ' KB';
				return (b / 1024 / 1024).toFixed(1) + ' MB';
			}

			async function setFile(file) {
				if (!file) return;
				setBusy(true, 'Reading…');
				try {
					const { PDFDocument } = await loadPdfLib();
					const bytes = new Uint8Array(await file.arrayBuffer());
					const doc = await PDFDocument.load(bytes, { ignoreEncryption: true });
					const total = doc.getPageCount();
					current = { file, bytes, total, base: file.name.replace(/\.pdf$/i, '') || 'document' };
					$('fname').textContent = file.name;
					$('fsub').textContent = total + ' pages · ' + fmtSize(file.size);
					loaded.hidden = false;
					drop.hidden = true;
					setBusy(false, '');
				} catch (err) {
					console.error(err);
					current = null;
					setBusy(false, '⚠ Could not read that PDF.');
				}
			}

			// "1, 3-5" -> Set of 0-based indices within [0,total)
			function parsePages(str, total) {
				const set = new Set();
				for (const part of (str || '').split(',')) {
					const p = part.trim();
					if (!p) continue;
					const m = p.match(/^(\d+)\s*-\s*(\d+)$/);
					if (m) {
						let a = parseInt(m[1], 10),
							b = parseInt(m[2], 10);
						if (a > b) [a, b] = [b, a];
						for (let n = a; n <= b; n++) if (n >= 1 && n <= total) set.add(n - 1);
					} else if (/^\d+$/.test(p)) {
						const n = parseInt(p, 10);
						if (n >= 1 && n <= total) set.add(n - 1);
					} else {
						throw new Error('Invalid page list: "' + p + '"');
					}
				}
				if (set.size === 0) throw new Error('No valid pages selected');
				return set;
			}

			async function rotate() {
				if (!current) return;
				setBusy(true, 'Rotating…');
				try {
					const { PDFDocument, degrees } = await loadPdfLib();
					const delta = parseInt(document.querySelector('input[name="deg"]:checked').value, 10);
					const scope = document.querySelector('input[name="scope"]:checked').value;
					const doc = await PDFDocument.load(current.bytes, { ignoreEncryption: true });
					const pages = doc.getPages();
					const targets =
						scope === 'all'
							? new Set(pages.map((_, i) => i))
							: parsePages($('pages').value, current.total);
					let n = 0;
					pages.forEach((page, i) => {
						if (!targets.has(i)) return;
						const cur = page.getRotation().angle || 0;
						page.setRotation(degrees(((cur + delta) % 360 + 360) % 360));
						n++;
					});
					const data = await doc.save();
					downloadBlob(data, current.base + '_rotated.pdf');
					setBusy(false, '✓ Rotated ' + n + ' page' + (n === 1 ? '' : 's') + ' — downloaded.');
				} catch (err) {
					console.error(err);
					setBusy(false, '⚠ ' + (err && err.message ? err.message : 'Something went wrong.'));
				}
			}

			function downloadBlob(data, name) {
				const blob = new Blob([data], { type: 'application/pdf' });
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				a.download = name;
				document.body.appendChild(a);
				a.click();
				a.remove();
				setTimeout(() => URL.revokeObjectURL(url), 5000);
			}
			function setBusy(busy, msg) {
				$('rotate-btn').disabled = busy;
				statusEl.textContent = msg || '';
				statusEl.className = 'status' + (msg && msg[0] === '⚠' ? ' err' : '');
			}

			drop.addEventListener('click', () => input.click());
			drop.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' || e.key === ' ') {
					e.preventDefault();
					input.click();
				}
			});
			input.addEventListener('change', (e) => {
				if (e.target.files[0]) setFile(e.target.files[0]);
				input.value = '';
			});
			['dragover', 'dragenter'].forEach((ev) =>
				drop.addEventListener(ev, (e) => {
					e.preventDefault();
					drop.classList.add('over');
				})
			);
			['dragleave', 'drop'].forEach((ev) =>
				drop.addEventListener(ev, (e) => {
					e.preventDefault();
					drop.classList.remove('over');
				})
			);
			drop.addEventListener('drop', (e) => {
				if (e.dataTransfer && e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]);
			});
			$('change-btn').addEventListener('click', () => {
				current = null;
				loaded.hidden = true;
				drop.hidden = false;
				setBusy(false, '');
			});
			$('rotate-btn').addEventListener('click', rotate);
			document.querySelectorAll('input[name="scope"]').forEach((r) =>
				r.addEventListener('change', () => {
					$('pages-input').hidden = document.querySelector('input[name="scope"]:checked').value !== 'some';
				})
			);
		</script>

		<style>
			.crumbs { font-size: 0.8em; color: rgb(var(--gray)); margin-bottom: 1em; }
			.crumbs a { color: rgb(var(--gray)); }
			.lede { font-size: 1.15em; color: rgb(var(--gray-dark)); }
			.app { margin: 2em 0 3em; }
			.drop {
				border: 2px dashed rgb(var(--gray)); border-radius: 14px; padding: 2.5em 1em;
				text-align: center; cursor: pointer; background: #fff;
				transition: border-color 0.15s ease, background 0.15s ease;
			}
			.drop:hover, .drop:focus, .drop.over { border-color: var(--accent); background: rgba(35,55,255,0.04); outline: none; }
			.drop-big { font-size: 1.3em; font-weight: 700; margin: 0 0 0.25em; }
			.drop-sub { margin: 0; color: rgb(var(--gray)); font-size: 0.9em; }
			.drop .link { color: var(--accent); text-decoration: underline; }
			.loaded { border: 1px solid rgb(var(--gray-light)); border-radius: 12px; padding: 1em 1.1em; background: #fff; }
			.file-row { display: flex; align-items: center; gap: 0.6em; }
			.badge { font-size: 0.65em; font-weight: 700; padding: 0.2em 0.45em; border-radius: 4px; color: #fff; flex: none; background: #9a2515; }
			.meta { display: flex; flex-direction: column; min-width: 0; flex: 1; }
			.fname { font-size: 0.95em; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
			.fsub { font-size: 0.75em; color: rgb(var(--gray)); }
			.rb { border: 1px solid rgb(var(--gray-light)); background: #fff; border-radius: 6px; width: 2em; height: 2em; cursor: pointer; flex: none; }
			.rb:hover { border-color: #9a2515; color: #9a2515; }
			.group { border: none; margin: 1.25em 0 0; padding: 0; }
			.group legend { font-weight: 700; font-size: 0.9em; padding: 0; margin-bottom: 0.5em; }
			.seg { display: inline-flex; border: 1px solid rgb(var(--gray-light)); border-radius: 8px; overflow: hidden; }
			.seg label { padding: 0.5em 1em; cursor: pointer; border-right: 1px solid rgb(var(--gray-light)); font-size: 0.9em; }
			.seg label:last-child { border-right: none; }
			.seg input { position: absolute; opacity: 0; pointer-events: none; }
			.seg label:has(input:checked) { background: var(--accent); color: #fff; }
			.mode { display: flex; align-items: center; gap: 0.5em; padding: 0.4em 0; cursor: pointer; font-size: 0.95em; }
			.mode-input { padding: 0.25em 0 0.5em 1.6em; }
			.mode-input input { width: 14em; max-width: 100%; padding: 0.45em 0.6em; border: 1px solid rgb(var(--gray-light)); border-radius: 6px; font-size: 0.9em; }
			.mode-input input:focus { outline: 2px solid var(--accent); border-color: var(--accent); }
			.actions { display: flex; align-items: center; gap: 0.75em; margin-top: 1em; flex-wrap: wrap; }
			button.primary { background: var(--accent); color: #fff; border: none; border-radius: 8px; padding: 0.7em 1.4em; font-size: 1em; font-weight: 700; cursor: pointer; }
			button.primary:disabled { opacity: 0.6; cursor: default; }
			.status { font-size: 0.85em; color: #0d7a3f; font-weight: 700; }
			.status.err { color: #9a2515; }
			.privacy { margin: 1em 0 0; font-size: 0.82em; color: rgb(var(--gray-dark)); }
			.prose h2 { margin-top: 1.5em; }
			.prose .faq { border: 1px solid rgb(var(--gray-light)); border-radius: 8px; padding: 0.75em 1em; margin-bottom: 0.6em; }
			.prose .faq summary { cursor: pointer; font-weight: 700; font-size: 0.95em; }
			.prose .faq p { margin: 0.75em 0 0; font-size: 0.92em; }
			.recommends { background: rgba(var(--gray-light), 40%); border-radius: 12px; padding: 1.25em 1.5em; margin: 2.5em 0; }
			.recommends h2 { margin-top: 0; font-size: 1.6em; }
			.back { margin-top: 2em; }
		</style>
	</body>
</html>
