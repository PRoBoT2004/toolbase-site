---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Freelance Rate Increase Calculator, How Many Clients Can You Afford to Lose? | Toolbase';
const description =
	'Raising your rates? See exactly how many clients you can lose and still earn more than you do now. Models your new income, your break-even churn, and the hours you’d free up. Free, instant, no sign-up.';

const faqs = [
	{
		q: 'How many clients can I afford to lose when I raise my rates?',
		a: 'More than you think. If you raise rates by 25%, you can lose up to 20% of your clients and still earn exactly what you earn today, and anything less than that means you earn more while working fewer hours. The exact break-even is increase ÷ (1 + increase). This calculator works out the client count for you.',
	},
	{
		q: 'What is a good amount to raise freelance rates by?',
		a: 'A 10–20% rise is rarely questioned by good clients. If almost every client and prospect says yes to your current rate, you are too cheap, keep raising until roughly 20–30% start saying no. Losing some price-sensitive clients is the goal of a rate increase, not a side effect.',
	},
	{
		q: 'Won’t I lose income if clients leave?',
		a: 'Usually the opposite. Because each remaining client now pays more, you can lose a meaningful share of them and still match your old income, then every client you keep beyond that break-even point is pure upside, earned in fewer hours. The scenario table on this page shows your income at each level of client loss.',
	},
	{
		q: 'Should I raise rates on existing clients or only new ones?',
		a: 'Both, on different timelines. New clients get the new rate immediately. Existing clients get notice, typically 30–60 days, with a short, confident message. Use the break-even number here to go into that conversation knowing you are protected even if a couple say no.',
	},
	{
		q: 'How do I tell clients about a price increase?',
		a: 'Keep it brief and matter-of-fact: state the new rate, the date it takes effect, and thank them, no lengthy justification or apology. Confidence does most of the work. Knowing your break-even churn (from this tool) is what lets you send that message without flinching.',
	},
];

const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
});

const appJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Freelance Rate Increase Calculator',
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Any (web browser)',
	url: 'https://gettoolbase.org/tools/rate-increase-calculator/',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	description: description,
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://gettoolbase.org/tools/' },
		{
			'@type': 'ListItem',
			position: 3,
			name: 'Rate Increase Calculator',
			item: 'https://gettoolbase.org/tools/rate-increase-calculator/',
		},
	],
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={faqJsonLd} />
		<script type="application/ld+json" is:inline set:html={appJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/tools/">Tools</a> › <span>Rate Increase Calculator</span>
			</nav>

			<h1>Freelance Rate Increase Calculator</h1>
			<p class="lede">
				The reason freelancers stay underpaid is the fear of losing clients. This kills it with a
				number: raise your rate, and see exactly <em>how many clients you can afford to lose</em> and
				still earn more than you do today, plus the hours you'd win back. Runs entirely in your browser.
			</p>

			<section class="calc" aria-label="Rate increase calculator">
				<div class="calc-grid">
					<div class="inputs">
						<div class="field">
							<label for="currency">Currency</label>
							<select id="currency">
								<option value="USD">$ USD, US Dollar</option>
								<option value="EUR">€ EUR, Euro</option>
								<option value="GBP">£ GBP, British Pound</option>
								<option value="INR">₹ INR, Indian Rupee</option>
								<option value="CAD">$ CAD, Canadian Dollar</option>
								<option value="AUD">$ AUD, Australian Dollar</option>
							</select>
						</div>
						<div class="field">
							<label for="income">Current monthly income (from these clients)</label>
							<input id="income" type="number" min="0" step="100" inputmode="numeric" value="6000" />
						</div>
						<div class="field">
							<label for="clients">Number of clients</label>
							<input id="clients" type="number" min="1" max="500" step="1" inputmode="numeric" value="10" />
							<small>Roughly how many clients make up that income.</small>
						</div>
						<div class="field">
							<label for="increase">Rate increase (%)</label>
							<input id="increase" type="number" min="0" max="500" step="5" inputmode="numeric" value="25" />
						</div>
						<div class="field">
							<label for="hours">Avg hours per client / month (optional)</label>
							<input id="hours" type="number" min="0" step="1" inputmode="numeric" placeholder="e.g. 12" />
							<small>Fill this to see the hours you'd free up.</small>
						</div>
					</div>

					<div class="result">
						<div class="headline">
							<span class="label">You can lose up to</span>
							<span class="rate" id="out-canlose">,</span>
							<span class="per" id="out-canlose-sub">clients and still earn the same</span>
						</div>
						<div class="secondary">
							<div>
								<span class="s-label">New income if all stay</span>
								<span class="s-val" id="out-allstay">,</span>
							</div>
							<div>
								<span class="s-label">Revenue you can lose</span>
								<span class="s-val" id="out-revloss">,</span>
							</div>
							<div id="hours-row" hidden>
								<span class="s-label">Hours freed at break-even</span>
								<span class="s-val" id="out-hoursfreed">,</span>
							</div>
						</div>
						<div class="verdict" id="verdict">
							<span class="v-line" id="v-line">,</span>
						</div>
					</div>
				</div>

				<h2 class="scenario-head">What you'd earn at each level of client loss</h2>
				<div class="scenario-wrap">
					<table class="scenario">
						<thead>
							<tr>
								<th>Clients lost</th>
								<th>Clients kept</th>
								<th class="num">New monthly income</th>
								<th class="num">vs now</th>
							</tr>
						</thead>
						<tbody id="scenario-body"></tbody>
					</table>
				</div>
				<p class="disclaimer">
					Assumes your clients are roughly equal in value and the new rate applies to all of them. A
					planning estimate to size the decision, your real client mix will vary.
				</p>
				<p class="cross">Related: <a href="/tools/freelance-rate-calculator/">Freelance rate calculator</a> · <a href="/tools/project-quote-calculator/">Project quote calculator</a></p>
			</section>

			<div class="prose">
				<h2>The math that makes raising rates safe</h2>
				<p>
					Every client you keep after a rate rise pays more, so your income holds up even as some leave.
					The break-even point, the share of clients you can lose before you earn less than today, is
					simply:
				</p>
				<blockquote>break-even loss = increase ÷ (1 + increase)</blockquote>
				<p>
					A 25% rise means you break even after losing 20% of your clients. A 50% rise means you can
					lose a third of them and still match today's income. Below that line you're earning <em>more
					for less work</em>. That's the whole case for raising rates, in one fraction, and it's why
					the fear of "losing clients" is almost always overblown.
				</p>

				<h2>When to raise your freelance rates</h2>
				<p>
					Raise when any of these are true: your skills or results have visibly improved; you're booked
					solid and turning work away; your costs have gone up; or, the big one, almost nobody ever
					pushes back on your price. If every prospect says yes, you are leaving money on the table.
					The goal is to nudge your rate up until roughly 20–30% of prospects decline. The ones who
					stay value you correctly; the ones who leave were the price-sensitive clients eating your
					time. Losing a few of them is the point.
				</p>

				<h2>Frequently asked questions</h2>
				{
					faqs.map((f) => (
						<details class="faq">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>

			<!--
				MONETIZATION: outbound links are affiliate-ready.
				Swap each href for the tracked affiliate URL on approval and change
				rel to "sponsored noopener". Until then: plain rel="nofollow noopener"
				links to the real homepages, nothing fake is shipped.
			-->
			<aside class="recommends">
				<h2>Make the new rate stick</h2>
				<p>What helps when you roll out higher prices:</p>
				<ul>
					<li><a href="https://www.bonsai.com/" rel="nofollow noopener" target="_blank">Bonsai</a>, proposals &amp; contracts that present a higher rate professionally.</li>
					<li><a href="https://www.freshbooks.com/" rel="nofollow noopener" target="_blank">FreshBooks</a>, invoice at the new rate and track who's on which plan.</li>
					<li><a href="https://toggl.com/track/" rel="nofollow noopener" target="_blank">Toggl Track</a>, prove the hours you save once the low-value clients drop off.</li>
				</ul>
				<p class="tiny">We only list tools we'd use ourselves. Some links may become affiliate links, it never changes what we recommend or costs you anything.</p>
			</aside>

			<p class="back"><a href="/tools/">← All Toolbase tools</a></p>
		</main>
		<Footer />

		<script>
			const ids = ['currency', 'income', 'clients', 'increase', 'hours'];
			const DEFAULTS = { currency: 'USD', income: 6000, clients: 10, increase: 25, hours: '' };
			const KEY = 'tb-rate-increase';

			const $ = (id) => document.getElementById(id);
			const num = (id) => {
				const v = parseFloat($(id).value);
				return isNaN(v) ? 0 : v;
			};
			const has = (id) => $(id).value.trim() !== '' && !isNaN(parseFloat($(id).value));

			function money(value, currency) {
				try {
					return new Intl.NumberFormat(undefined, {
						style: 'currency',
						currency,
						maximumFractionDigits: 0,
					}).format(value);
				} catch (e) {
					return Math.round(value).toString();
				}
			}

			function compute() {
				const currency = $('currency').value;
				const income = num('income');
				const clients = Math.round(num('clients'));
				const inc = num('increase') / 100;
				const valid = income > 0 && clients > 0 && inc >= 0;

				const perClient = valid ? income / clients : 0;
				const newPerClient = perClient * (1 + inc);
				const allStay = income * (1 + inc);

				// break-even: keep at least ceil(clients / (1+inc)) clients
				const keepNeeded = inc > 0 ? Math.ceil(clients / (1 + inc)) : clients;
				const canLose = Math.max(0, clients - keepNeeded);
				const revLossFrac = inc > 0 ? inc / (1 + inc) : 0;

				$('out-canlose').textContent = valid ? canLose.toString() : ',';
				$('out-canlose-sub').textContent =
					canLose === 1 ? 'client and still earn the same' : 'clients and still earn the same';
				$('out-allstay').textContent = valid ? money(allStay, currency) : ',';
				$('out-revloss').textContent = valid ? (revLossFrac * 100).toFixed(0) + '%' : ',';

				const hoursRow = $('hours-row');
				if (has('hours') && valid) {
					const avg = num('hours');
					const hoursFreed = canLose * avg;
					hoursRow.hidden = false;
					$('out-hoursfreed').textContent = hoursFreed.toLocaleString() + ' hrs/mo';
				} else {
					hoursRow.hidden = true;
				}

				const vLine = $('v-line');
				if (!valid) {
					vLine.textContent = 'Enter your numbers to see the verdict';
				} else if (inc === 0) {
					vLine.textContent = 'Add a rate increase to see your break-even.';
				} else {
					vLine.innerHTML =
						'A <b>' +
						(inc * 100).toFixed(0) +
						'%</b> raise: lose fewer than <b>' +
						canLose +
						'</b> of your ' +
						clients +
						' clients and you earn <b>more, for less work</b>.';
				}

				// scenario table
				const maxRow = Math.min(clients, canLose + 3);
				let rows = '';
				for (let lost = 0; lost <= maxRow; lost++) {
					const kept = clients - lost;
					const newIncome = kept * newPerClient;
					const delta = newIncome - income;
					const isBreak = lost === canLose;
					const cls = isBreak ? ' class="break"' : delta < 0 ? ' class="down"' : '';
					const deltaStr = (delta >= 0 ? '+' : '−') + money(Math.abs(delta), currency);
					rows +=
						'<tr' +
						cls +
						'><td>' +
						lost +
						(isBreak ? ' · break-even' : '') +
						'</td><td>' +
						kept +
						'</td><td class="num">' +
						money(newIncome, currency) +
						'</td><td class="num">' +
						deltaStr +
						'</td></tr>';
				}
				$('scenario-body').innerHTML = valid ? rows : '<tr><td colspan="4">,</td></tr>';

				save();
			}

			function save() {
				const data = {};
				ids.forEach((id) => (data[id] = $(id).value));
				try {
					localStorage.setItem(KEY, JSON.stringify(data));
				} catch (e) {}
			}
			function load() {
				try {
					const raw = localStorage.getItem(KEY);
					if (!raw) return;
					const data = JSON.parse(raw);
					ids.forEach((id) => {
						if (data[id] !== undefined) $(id).value = data[id];
					});
				} catch (e) {}
			}

			ids.forEach((id) => {
				$(id).addEventListener('input', compute);
				$(id).addEventListener('change', compute);
				$(id).addEventListener('wheel', (e) => {
					if (document.activeElement === e.target) e.target.blur();
				});
			});

			load();
			compute();
		</script>

		<style>
			.crumbs {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
			}
			.crumbs a {
				color: rgb(var(--gray));
			}
			.lede {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
			}
			.calc {
				margin: 2em 0 3em;
			}
			.calc-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5em;
			}
			.inputs {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.25em;
			}
			.field {
				margin-bottom: 1em;
			}
			.field label {
				display: block;
				font-weight: 700;
				font-size: 0.85em;
				margin-bottom: 0.25em;
			}
			.field input,
			.field select {
				width: 100%;
				padding: 0.55em 0.6em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: #fff;
				box-sizing: border-box;
			}
			.field input:focus,
			.field select:focus {
				outline: 2px solid var(--accent);
				border-color: var(--accent);
			}
			.field small {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.72em;
				margin-top: 0.25em;
				line-height: 1.4;
			}
			.result {
				background: rgb(var(--gray-dark));
				color: #fff;
				border-radius: 12px;
				padding: 1.5em;
				position: sticky;
				top: 1em;
				align-self: start;
			}
			.headline {
				text-align: center;
				padding-bottom: 1em;
				border-bottom: 1px solid rgba(255, 255, 255, 0.15);
			}
			.headline .label {
				display: block;
				font-size: 0.8em;
				opacity: 0.7;
			}
			.headline .rate {
				display: block;
				font-size: 3.2em;
				font-weight: 700;
				line-height: 1.05;
				color: #fff;
			}
			.headline .per {
				display: block;
				font-size: 0.8em;
				opacity: 0.7;
			}
			.secondary {
				display: grid;
				gap: 0.6em;
				margin: 1em 0;
			}
			.secondary > div {
				display: flex;
				justify-content: space-between;
				font-size: 0.85em;
			}
			.secondary .s-label {
				opacity: 0.75;
			}
			.secondary .s-val {
				font-weight: 700;
			}
			.verdict {
				background: rgba(255, 255, 255, 0.1);
				border-radius: 8px;
				padding: 0.9em;
				text-align: center;
				font-size: 0.9em;
				line-height: 1.45;
			}
			.scenario-head {
				font-size: 1.4em;
				margin: 1.5em 0 0.6em;
			}
			.scenario-wrap {
				overflow-x: auto;
			}
			table.scenario {
				border-collapse: collapse;
				font-size: 0.92em;
			}
			table.scenario th,
			table.scenario td {
				padding: 0.5em 0.75em;
				border-bottom: 1px solid rgb(var(--gray-light));
				text-align: left;
			}
			table.scenario th.num,
			table.scenario td.num {
				text-align: right;
				white-space: nowrap;
			}
			table.scenario thead th {
				font-size: 0.78em;
				text-transform: uppercase;
				letter-spacing: 0.03em;
				color: rgb(var(--gray));
			}
			table.scenario tr.break {
				background: rgba(13, 122, 63, 0.12);
				font-weight: 700;
			}
			table.scenario tr.down {
				color: #9a2515;
			}
			.disclaimer {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin: 1em 0 0;
				line-height: 1.5;
			}
			.cross {
				font-size: 0.9em;
				margin: 0.5em 0 0;
			}
			.prose h2 {
				margin-top: 1.5em;
			}
			.prose blockquote {
				font-size: 1.1em;
				font-weight: 700;
			}
			.prose .faq {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.75em 1em;
				margin-bottom: 0.6em;
			}
			.prose .faq summary {
				cursor: pointer;
				font-weight: 700;
				font-size: 0.95em;
			}
			.prose .faq p {
				margin: 0.75em 0 0;
				font-size: 0.92em;
			}
			.recommends {
				background: rgba(var(--gray-light), 40%);
				border-radius: 12px;
				padding: 1.25em 1.5em;
				margin: 2.5em 0;
			}
			.recommends h2 {
				margin-top: 0;
				font-size: 1.6em;
			}
			.recommends .tiny {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin-bottom: 0;
			}
			.back {
				margin-top: 2em;
			}
			@media (max-width: 720px) {
				.calc-grid {
					grid-template-columns: 1fr;
				}
				.result {
					position: static;
				}
			}
		</style>
	</body>
</html>
