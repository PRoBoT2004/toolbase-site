---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const title = 'Freelance Hourly Rate Calculator — Free, No Sign-Up | Toolbase';
const description =
	'Work out exactly what to charge per hour as a freelancer. Factors in your target take-home income, business expenses, taxes, billable hours and time off. Free, instant, runs entirely in your browser — no sign-up.';

const faqs = [
	{
		q: 'How much should I charge per hour as a freelancer?',
		a: 'Start from the income you actually want to take home, add your annual business expenses, gross that up for the taxes you set aside, add a small buffer, then divide by the number of hours you can realistically bill in a year (not the hours you work — the hours a client pays for). For most full-time freelancers that lands meaningfully higher than their old salary divided by 2,080.',
	},
	{
		q: 'Why is my freelance rate higher than my old salary worked out to?',
		a: 'An employee is paid for ~2,080 hours a year and gets paid holidays, sick days, employer-funded taxes, software and a pension. A freelancer bills far fewer hours (admin, sales and downtime are unpaid), pays both halves of their taxes, buys their own tools, and gets paid nothing for time off. Your rate has to cover all of that, so it is correctly much higher than a naive salary-per-hour figure.',
	},
	{
		q: 'How many hours can a freelancer actually bill per week?',
		a: 'Almost nobody bills 40. Once you remove sales, admin, invoicing, learning and gaps between projects, 20 to 30 billable hours a week is realistic for an established full-time freelancer. The calculator defaults to 25 for this reason — using 40 will quietly under-price you.',
	},
	{
		q: 'Should I charge hourly or per project?',
		a: 'Use the hourly number from this calculator as your internal floor — the minimum your time is worth. Then quote clients a fixed project price based on your estimated hours times that floor (plus margin). You capture the upside when you work efficiently, and the client gets price certainty.',
	},
	{
		q: 'Do I need to include taxes in my rate?',
		a: 'Yes. The money a client pays you is not yours — a chunk goes to income tax and self-employment / national insurance. Enter the percentage you set aside and the calculator grosses your rate up so that what is left after tax still covers your target income.',
	},
];

const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
});

const appJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'Freelance Hourly Rate Calculator',
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Any (web browser)',
	url: 'https://gettoolbase.org/tools/freelance-rate-calculator/',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	description: description,
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://gettoolbase.org/tools/' },
		{
			'@type': 'ListItem',
			position: 3,
			name: 'Freelance Rate Calculator',
			item: 'https://gettoolbase.org/tools/freelance-rate-calculator/',
		},
	],
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={faqJsonLd} />
		<script type="application/ld+json" is:inline set:html={appJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> › <a href="/tools/">Tools</a> › <span>Freelance Rate Calculator</span>
			</nav>

			<h1>Freelance Hourly Rate Calculator</h1>
			<p class="lede">
				Stop guessing what to charge. Enter the income you actually want to take home and this
				calculator works out the hourly rate you need — after expenses, taxes and the fact that you
				can't bill every hour you work. Runs entirely in your browser. Nothing is sent anywhere.
			</p>

			<section class="calc" aria-label="Freelance rate calculator">
				<div class="calc-grid">
					<div class="inputs">
						<div class="field">
							<label for="currency">Currency</label>
							<select id="currency">
								<option value="USD">$ USD — US Dollar</option>
								<option value="EUR">€ EUR — Euro</option>
								<option value="GBP">£ GBP — British Pound</option>
								<option value="INR">₹ INR — Indian Rupee</option>
								<option value="CAD">$ CAD — Canadian Dollar</option>
								<option value="AUD">$ AUD — Australian Dollar</option>
							</select>
						</div>

						<div class="field">
							<label for="income">Target take-home income (per year)</label>
							<input id="income" type="number" min="0" step="1000" inputmode="numeric" value="60000" />
							<small>What you want to actually keep after tax and expenses.</small>
						</div>

						<div class="field">
							<label for="expenses">Annual business expenses</label>
							<input id="expenses" type="number" min="0" step="500" inputmode="numeric" value="6000" />
							<small>Software, hardware, subscriptions, accountant, insurance.</small>
						</div>

						<div class="field">
							<label for="tax">Tax set-aside (%)</label>
							<input id="tax" type="number" min="0" max="90" step="1" inputmode="numeric" value="25" />
							<small>Income + self-employment tax you put aside.</small>
						</div>

						<div class="field">
							<label for="hours">Billable hours per week</label>
							<input id="hours" type="number" min="1" max="80" step="1" inputmode="numeric" value="25" />
							<small>Hours a client actually pays for — not hours worked.</small>
						</div>

						<div class="field">
							<label for="weeks">Working weeks per year</label>
							<input id="weeks" type="number" min="1" max="52" step="1" inputmode="numeric" value="46" />
							<small>52 minus your holidays, sick days and downtime.</small>
						</div>

						<div class="field">
							<label for="buffer">Profit buffer (%)</label>
							<input id="buffer" type="number" min="0" max="100" step="1" inputmode="numeric" value="10" />
							<small>Cushion for late payers, scope creep and slow months.</small>
						</div>

						<button id="reset" type="button" class="reset">Reset to defaults</button>
					</div>

					<div class="result" aria-live="polite">
						<div class="headline">
							<span class="label">You should charge</span>
							<span class="rate" id="out-hourly">—</span>
							<span class="per">per hour</span>
						</div>
						<div class="secondary">
							<div>
								<span class="s-label">Day rate (8 billable hrs)</span>
								<span class="s-val" id="out-day">—</span>
							</div>
							<div>
								<span class="s-label">Annual revenue target</span>
								<span class="s-val" id="out-revenue">—</span>
							</div>
							<div>
								<span class="s-label">Billable hours / year</span>
								<span class="s-val" id="out-billable">—</span>
							</div>
						</div>

						<details class="breakdown">
							<summary>Show the math</summary>
							<table>
								<tbody id="breakdown-body"></tbody>
							</table>
						</details>
						<p class="disclaimer">
							Estimate only — your real tax situation, region and market set the final number. This is
							your floor, not a ceiling.
						</p>
					</div>
				</div>
			</section>

			<div class="prose">
				<h2>How to calculate your freelance hourly rate</h2>
				<p>
					The mistake almost every new freelancer makes is dividing their old salary by 2,080 hours
					and quoting that. It guarantees you earn <em>less</em> than you did as an employee, because
					you're now also paying for taxes your employer used to cover, tools they used to buy, and
					all the unpaid time between projects. The correct method works backwards from the life you
					want, not from a salary you've left behind:
				</p>
				<ol>
					<li><strong>Start with the income you want to keep.</strong> Your real target — what hits your bank account after everything.</li>
					<li><strong>Add your annual business expenses.</strong> Software, hardware, your accountant, insurance — the cost of running you.</li>
					<li><strong>Gross it up for tax.</strong> Divide by (1 − your tax rate) so the money left after tax still covers your target.</li>
					<li><strong>Add a buffer.</strong> Late payers, scope creep and dry spells are guaranteed. A 10% cushion is sensible.</li>
					<li><strong>Divide by your real billable hours.</strong> Weekly billable hours × working weeks. This is the number that surprises people — and the one that makes your rate correct.</li>
				</ol>

				<h2>Why your freelance rate looks "too high" (it isn't)</h2>
				<p>
					A $60,000 salary feels like about $29/hour. But that employee was paid for 40 hours a week,
					52 weeks a year, with paid holidays, sick leave, employer tax contributions, a pension and a
					laptop they didn't buy. A freelancer aiming for the same take-home, billing 25 hours a week
					for 46 weeks while covering their own taxes and tools, needs to charge roughly
					<strong>three times</strong> that headline rate just to break even on the same lifestyle.
					Charging less isn't being competitive — it's quietly working for free.
				</p>

				<h2>Frequently asked questions</h2>
				{
					faqs.map((f) => (
						<details class="faq">
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))
				}
			</div>

			<!--
				MONETIZATION: outbound links below are affiliate-ready.
				When affiliate programs are approved, swap each href for the tracked
				affiliate URL and change rel to "sponsored noopener". Until then they
				are plain rel="nofollow noopener" links to the real product homepages —
				nothing fake is shipped.
			-->
			<aside class="recommends">
				<h2>Once you've set your rate</h2>
				<p>The tools freelancers use to actually bill that rate and get paid on time:</p>
				<ul>
					<li><a href="https://www.freshbooks.com/" rel="nofollow noopener" target="_blank">FreshBooks</a> — invoicing &amp; accounting built for freelancers.</li>
					<li><a href="https://toggl.com/track/" rel="nofollow noopener" target="_blank">Toggl Track</a> — track billable vs non-billable hours so your assumptions stay honest.</li>
					<li><a href="https://www.wave.com/" rel="nofollow noopener" target="_blank">Wave</a> — free invoicing if you're just starting out.</li>
				</ul>
				<p class="tiny">We only list tools we'd use ourselves. Some links may become affiliate links — it never changes what we recommend or costs you anything.</p>
			</aside>

			<p class="back"><a href="/tools/">← All Toolbase tools</a></p>
		</main>
		<Footer />

		<script>
			const ids = ['currency', 'income', 'expenses', 'tax', 'hours', 'weeks', 'buffer'];
			const DEFAULTS = {
				currency: 'USD',
				income: 60000,
				expenses: 6000,
				tax: 25,
				hours: 25,
				weeks: 46,
				buffer: 10,
			};
			const KEY = 'tb-freelance-rate';

			const $ = (id) => document.getElementById(id);
			const num = (id) => {
				const v = parseFloat($(id).value);
				return isNaN(v) ? 0 : v;
			};

			function money(value, currency) {
				try {
					return new Intl.NumberFormat(undefined, {
						style: 'currency',
						currency,
						maximumFractionDigits: 0,
					}).format(value);
				} catch (e) {
					return value.toFixed(0);
				}
			}
			function money2(value, currency) {
				try {
					return new Intl.NumberFormat(undefined, {
						style: 'currency',
						currency,
						maximumFractionDigits: value < 100 ? 2 : 0,
					}).format(value);
				} catch (e) {
					return value.toFixed(2);
				}
			}

			function compute() {
				const currency = $('currency').value;
				const income = num('income');
				const expenses = num('expenses');
				const tax = Math.min(num('tax'), 90) / 100;
				const hours = num('hours');
				const weeks = num('weeks');
				const buffer = num('buffer') / 100;

				const billable = hours * weeks;
				const baseNeed = income + expenses;
				const grossTax = tax < 1 ? baseNeed / (1 - tax) : baseNeed;
				const withBuffer = grossTax * (1 + buffer);
				const valid = billable > 0 && (income > 0 || expenses > 0);
				const hourly = valid ? withBuffer / billable : 0;
				const day = hourly * 8;

				$('out-hourly').textContent = valid ? money2(hourly, currency) : '—';
				$('out-day').textContent = valid ? money(day, currency) : '—';
				$('out-revenue').textContent = valid ? money(withBuffer, currency) : '—';
				$('out-billable').textContent = valid ? billable.toLocaleString() + ' hrs' : '—';

				const rows = [
					['Target take-home income', money(income, currency)],
					['+ Business expenses', money(expenses, currency)],
					['= Money you must clear', money(baseNeed, currency)],
					[`÷ (1 − ${(tax * 100).toFixed(0)}% tax) → revenue before tax`, money(grossTax, currency)],
					[`+ ${(buffer * 100).toFixed(0)}% buffer → revenue target`, money(withBuffer, currency)],
					[`÷ billable hours (${hours} × ${weeks} = ${billable.toLocaleString()})`, valid ? money2(hourly, currency) + ' / hr' : '—'],
				];
				$('breakdown-body').innerHTML = rows
					.map((r) => `<tr><td>${r[0]}</td><td class="amt">${r[1]}</td></tr>`)
					.join('');

				save();
			}

			function save() {
				const data = {};
				ids.forEach((id) => (data[id] = $(id).value));
				try {
					localStorage.setItem(KEY, JSON.stringify(data));
				} catch (e) {}
			}
			function load() {
				try {
					const raw = localStorage.getItem(KEY);
					if (!raw) return;
					const data = JSON.parse(raw);
					ids.forEach((id) => {
						if (data[id] !== undefined && data[id] !== '') $(id).value = data[id];
					});
				} catch (e) {}
			}

			ids.forEach((id) => {
				$(id).addEventListener('input', compute);
				$(id).addEventListener('change', compute);
				// scrolling over a focused number field silently changes it — block that
				$(id).addEventListener('wheel', (e) => {
					if (document.activeElement === e.target) e.target.blur();
				});
			});
			$('reset').addEventListener('click', () => {
				ids.forEach((id) => ($(id).value = DEFAULTS[id]));
				compute();
			});

			load();
			compute();
		</script>

		<style>
			.crumbs {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
			}
			.crumbs a {
				color: rgb(var(--gray));
			}
			.lede {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
			}
			.calc {
				margin: 2em 0 3em;
			}
			.calc-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5em;
			}
			.inputs {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.25em;
			}
			.field {
				margin-bottom: 1em;
			}
			.field label {
				display: block;
				font-weight: 700;
				font-size: 0.85em;
				margin-bottom: 0.25em;
			}
			.field input,
			.field select {
				width: 100%;
				padding: 0.55em 0.6em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: #fff;
				box-sizing: border-box;
			}
			.field input:focus,
			.field select:focus {
				outline: 2px solid var(--accent);
				border-color: var(--accent);
			}
			.field small {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.72em;
				margin-top: 0.25em;
				line-height: 1.4;
			}
			.reset {
				background: none;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.5em 0.9em;
				cursor: pointer;
				font-size: 0.85em;
				color: rgb(var(--gray-dark));
			}
			.reset:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.result {
				background: rgb(var(--gray-dark));
				color: #fff;
				border-radius: 12px;
				padding: 1.5em;
				position: sticky;
				top: 1em;
				align-self: start;
			}
			.headline {
				text-align: center;
				padding-bottom: 1em;
				border-bottom: 1px solid rgba(255, 255, 255, 0.15);
			}
			.headline .label {
				display: block;
				font-size: 0.8em;
				opacity: 0.7;
			}
			.headline .rate {
				display: block;
				font-size: 3em;
				font-weight: 700;
				line-height: 1.1;
				color: #fff;
			}
			.headline .per {
				display: block;
				font-size: 0.85em;
				opacity: 0.7;
			}
			.secondary {
				display: grid;
				gap: 0.6em;
				margin: 1em 0;
			}
			.secondary > div {
				display: flex;
				justify-content: space-between;
				font-size: 0.85em;
			}
			.secondary .s-label {
				opacity: 0.75;
			}
			.secondary .s-val {
				font-weight: 700;
			}
			.breakdown {
				font-size: 0.8em;
				margin-top: 0.5em;
			}
			.breakdown summary {
				cursor: pointer;
				opacity: 0.85;
			}
			.breakdown table {
				margin-top: 0.75em;
				border-collapse: collapse;
			}
			.breakdown td {
				padding: 0.35em 0;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				vertical-align: top;
			}
			.breakdown td.amt {
				text-align: right;
				font-weight: 700;
				white-space: nowrap;
				padding-left: 1em;
			}
			.disclaimer {
				font-size: 0.72em;
				opacity: 0.6;
				margin: 1em 0 0;
				line-height: 1.5;
			}
			.prose h2 {
				margin-top: 1.5em;
			}
			.faq,
			.breakdown {
				margin-bottom: 0;
			}
			.prose .faq {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.75em 1em;
				margin-bottom: 0.6em;
			}
			.prose .faq summary {
				cursor: pointer;
				font-weight: 700;
				font-size: 0.95em;
			}
			.prose .faq p {
				margin: 0.75em 0 0;
				font-size: 0.92em;
			}
			.recommends {
				background: rgba(var(--gray-light), 40%);
				border-radius: 12px;
				padding: 1.25em 1.5em;
				margin: 2.5em 0;
			}
			.recommends h2 {
				margin-top: 0;
				font-size: 1.6em;
			}
			.recommends .tiny {
				font-size: 0.72em;
				color: rgb(var(--gray));
				margin-bottom: 0;
			}
			.back {
				margin-top: 2em;
			}
			@media (max-width: 720px) {
				.calc-grid {
					grid-template-columns: 1fr;
				}
				.result {
					position: static;
				}
			}
		</style>
	</body>
</html>
