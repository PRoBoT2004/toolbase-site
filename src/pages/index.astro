---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latest = posts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<span class="eyebrow">The honest filter</span>
				<h1>The AI tool stack for solopreneurs.</h1>
				<p class="lede">
					Thousands of AI tools launch every month. Most are noise. A few are genuinely useful for
					solo founders, freelancers, and indie operators trying to run a business by themselves.
				</p>
				<p class="lede subdued">
					Toolbase tests, compares, and reviews the AI tools that actually save time and make money
					for one-person businesses, no fluff, no paid placements, no &quot;10 ways AI will change
					your life&quot; listicles.
				</p>
				<div class="cta-row">
					<a class="btn btn-primary" href="/blog/">Read the reviews</a>
					<a class="btn btn-ghost" href="/tools/">Use the free tools</a>
				</div>
			</section>

			<section class="cards">
				<a class="card" href="/blog/">
					<span class="card-tag">Reviews</span>
					<h3>Comparison guides</h3>
					<p>Head-to-head tests of the tools you're trying to choose between, actual outputs, not feature checklists.</p>
				</a>
				<a class="card" href="/tools/">
					<span class="card-tag">Free</span>
					<h3>Tools we built</h3>
					<p>Calculators, PDF, image and text tools for one-person businesses. No sign-up, nothing sent to a server.</p>
				</a>
				<a class="card" href="/about/">
					<span class="card-tag">About</span>
					<h3>Why we exist</h3>
					<p>Who's behind Toolbase, how we test, and how an honest review site stays honest when it earns from affiliate links.</p>
				</a>
			</section>

			<section class="tools-showcase">
				<div class="ts-head">
					<h2>Free tools, no sign-up</h2>
					<a href="/tools/" class="all-link">All tools →</a>
				</div>
				<div class="ts-grid">
					<a class="card" href="/tools/freelance-rate-calculator/">
						<span class="card-tag">Calculators</span>
						<h3>Freelance &amp; money</h3>
						<p>Rate, contract-vs-salary, project quote and rate-increase calculators.</p>
					</a>
					<a class="card" href="/tools/merge-pdf/">
						<span class="card-tag">PDF</span>
						<h3>PDF tools</h3>
						<p>Merge, split, JPG-to-PDF and rotate, your files never leave the browser.</p>
					</a>
					<a class="card" href="/tools/compress-image/">
						<span class="card-tag">Image</span>
						<h3>Image tools</h3>
						<p>Compress to a target KB, resize to exact pixels, convert PNG/JPG/WebP.</p>
					</a>
					<a class="card" href="/tools/word-counter/">
						<span class="card-tag">Text</span>
						<h3>Text &amp; dev tools</h3>
						<p>Word counter, case converter and a JSON formatter &amp; validator.</p>
					</a>
				</div>
			</section>

			<section class="latest">
				<div class="latest-head">
					<h2>Latest reviews</h2>
					<a href="/blog/" class="all-link">All articles →</a>
				</div>
				<ul class="post-grid">
					{
						latest.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<div class="post-hero">
											<Image width={720} height={405} src={post.data.heroImage} alt="" />
										</div>
									)}
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-desc">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<style>
			.home { max-width: var(--max-w-content); width: 100%; }

			/* Hero */
			.hero {
				padding: 3em 0 1em;
				max-width: 760px;
			}
			.eyebrow {
				display: inline-block;
				font-size: 0.75em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--accent-dark);
				margin-bottom: 1em;
			}
			.hero h1 {
				font-size: 3.3em;
				line-height: 1.05;
				letter-spacing: -0.025em;
				margin-bottom: 0.6em;
			}
			.lede {
				font-size: 1.2em;
				line-height: 1.55;
				color: rgb(var(--gray-dark));
				margin: 0 0 1em;
				max-width: 640px;
			}
			.lede.subdued { color: rgb(var(--gray)); font-size: 1.1em; }
			.cta-row {
				display: flex;
				gap: 0.75em;
				margin-top: 1.5em;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-block;
				padding: 0.75em 1.4em;
				border-radius: 999px;
				font-weight: 600;
				font-size: 1em;
				text-decoration: none;
				transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
			}
			.btn-primary {
				background: var(--accent);
				color: #fff;
				box-shadow: var(--shadow-sm);
			}
			.btn-primary:hover {
				background: var(--accent-dark);
				color: #fff;
				transform: translateY(-1px);
				box-shadow: var(--shadow-md);
			}
			.btn-ghost {
				background: transparent;
				color: rgb(var(--gray-dark));
				border: 1px solid rgb(var(--gray-light));
			}
			.btn-ghost:hover {
				color: rgb(var(--black));
				border-color: var(--accent);
				background: var(--accent-soft);
			}

			/* Three-up card row */
			.cards {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1em;
				margin: 3em 0 2em;
			}
			.card {
				display: block;
				background: var(--surface);
				border: 1px solid rgb(var(--gray-light));
				border-radius: var(--radius-md);
				padding: 1.5em 1.4em;
				text-decoration: none;
				color: inherit;
				transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
			}
			.card:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
				border-color: rgba(224, 120, 86, 0.4);
			}
			.card-tag {
				display: inline-block;
				font-size: 0.7em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--accent-dark);
				margin-bottom: 0.5em;
			}
			.card h3 { font-size: 1.25em; margin: 0 0 0.4em; }
			.card p { font-size: 0.92em; color: rgb(var(--gray-dark)); margin: 0; line-height: 1.5; }

			/* Tools showcase */
			.tools-showcase { margin-top: 1em; }
			.ts-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.25em;
			}
			.ts-head h2 { margin: 0; }
			.ts-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1em;
			}

			/* Latest articles */
			.latest { margin-top: 3em; }
			.latest-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.25em;
			}
			.latest-head h2 { margin: 0; }
			.all-link {
				font-size: 0.95em;
				color: var(--accent-dark);
				font-weight: 600;
				text-decoration: none;
			}
			.all-link:hover { color: var(--accent); }
			.post-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
			}
			.post-grid li { margin: 0; }
			.post-grid a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.post-hero {
				overflow: hidden;
				border-radius: var(--radius-md);
				margin-bottom: 0.9em;
				background: var(--surface-warm);
				aspect-ratio: 16 / 9;
			}
			.post-hero img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.4s ease;
			}
			.post-grid a:hover .post-hero img { transform: scale(1.03); }
			.post-date {
				font-size: 0.78em;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.05em;
				font-weight: 600;
			}
			.post-title {
				font-size: 1.2em;
				line-height: 1.25;
				margin: 0.35em 0 0.4em;
				color: rgb(var(--black));
			}
			.post-grid a:hover .post-title { color: var(--accent-dark); }
			.post-desc {
				font-size: 0.92em;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			@media (max-width: 860px) {
				.cards, .post-grid, .ts-grid { grid-template-columns: 1fr 1fr; }
			}
			@media (max-width: 600px) {
				.hero { padding: 1.5em 0 0.5em; }
				.hero h1 { font-size: 2.2em; }
				.cards, .post-grid, .ts-grid { grid-template-columns: 1fr; gap: 1em; }
				.btn { width: 100%; text-align: center; }
				.cta-row { flex-direction: column; }
			}
		</style>
	</body>
</html>
