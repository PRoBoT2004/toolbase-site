---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: number };

const { title, description, pubDate, updatedDate, heroImage, readingTime } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 2em 1em 0;
			}
			.reading-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 0%;
				height: 3px;
				background: var(--accent);
				z-index: 100;
				transition: width 0.08s linear;
				will-change: width;
			}
			.article-header {
				max-width: 820px;
				margin: 0 auto 2em;
				text-align: center;
			}
			.meta {
				color: rgb(var(--gray));
				font-size: 0.85em;
				display: inline-flex;
				align-items: center;
				gap: 0.6em;
				flex-wrap: wrap;
				justify-content: center;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				font-weight: 600;
			}
			.meta .sep { opacity: 0.4; }
			.last-updated-on {
				font-style: italic;
				display: block;
				margin-top: 0.4em;
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.article-header h1 {
				margin: 0.7em 0 0.5em;
				font-size: 3em;
				line-height: 1.08;
				letter-spacing: -0.025em;
			}
			.hero-image {
				max-width: 1080px;
				margin: 0 auto 2em;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-md);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 0 1em 2em;
				color: rgb(var(--gray-dark));
				font-size: 1.05em;
				line-height: 1.8;
			}
			.prose :global(p) { margin: 0 0 1.4em; }
			.prose :global(h2) { margin: 2em 0 0.6em; }
			.prose :global(h3) { margin: 1.5em 0 0.5em; }
			.prose :global(hr) { margin: 2.5em 0; }
			.prose :global(table) {
				margin: 1.5em 0;
				background: var(--surface);
				border-radius: var(--radius-md);
				overflow: hidden;
				box-shadow: var(--shadow-sm);
			}
			.prose :global(table th) {
				background: var(--surface-warm);
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 0.7em 0.9em;
				font-weight: 700;
			}
			.prose :global(table td) {
				padding: 0.7em 0.9em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.prose :global(table tr:last-child td) { border-bottom: none; }
			.prose :global(blockquote) {
				margin: 1.8em 0;
				background: var(--surface-warm);
				padding: 1em 1.25em;
				border-radius: var(--radius-sm);
			}
			@media (max-width: 720px) {
				.article-header h1 { font-size: 2em; }
				.prose { font-size: 1em; line-height: 1.7; padding: 0 0.5em 1em; }
			}
		</style>
	</head>

	<body>
		<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
		<Header />
		<main>
			<article id="article">
				<header class="article-header">
					<div class="meta">
						<FormattedDate date={pubDate} />
						{readingTime && (
							<>
								<span class="sep">·</span>
								<span>{readingTime} min read</span>
							</>
						)}
					</div>
					{
						updatedDate && (
							<div class="last-updated-on">
								Last updated on <FormattedDate date={updatedDate} />
							</div>
						)
					}
					<h1>{title}</h1>
				</header>
				{heroImage && (
					<div class="hero-image">
						<Image width={1200} height={675} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />

		<script>
			(function () {
				const bar = document.getElementById('reading-progress');
				const article = document.getElementById('article');
				if (!bar || !article) return;

				let ticking = false;
				function update() {
					const rect = article.getBoundingClientRect();
					const articleTop = rect.top + window.scrollY;
					const articleEnd = articleTop + article.scrollHeight - window.innerHeight;
					const range = Math.max(1, articleEnd - articleTop);
					const progress = Math.max(0, Math.min(1, (window.scrollY - articleTop) / range));
					bar.style.width = progress * 100 + '%';
					ticking = false;
				}
				function onScroll() {
					if (!ticking) {
						requestAnimationFrame(update);
						ticking = true;
					}
				}
				window.addEventListener('scroll', onScroll, { passive: true });
				window.addEventListener('resize', onScroll);
				update();
			})();
		</script>
	</body>
</html>
