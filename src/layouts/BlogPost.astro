---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: number };

const { title, description, pubDate, updatedDate, heroImage, readingTime } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const heroAbsoluteURL = heroImage ? new URL(heroImage.src, Astro.site).toString() : undefined;

const articleJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	image: heroAbsoluteURL ? [heroAbsoluteURL] : undefined,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
	author: { '@type': 'Organization', name: 'Toolbase', url: 'https://gettoolbase.org/' },
	publisher: {
		'@type': 'Organization',
		name: 'Toolbase',
		url: 'https://gettoolbase.org/',
		logo: { '@type': 'ImageObject', url: 'https://gettoolbase.org/favicon.svg' },
	},
});

const breadcrumbJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gettoolbase.org/' },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://gettoolbase.org/blog/' },
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.toString() },
	],
});
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<script type="application/ld+json" is:inline set:html={articleJsonLd} />
		<script type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0 auto;
				padding: 2em 1em 0;
			}
			.reading-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 0%;
				height: 3px;
				background: var(--accent);
				z-index: 100;
				transition: width 0.08s linear;
				will-change: width;
			}
			.article-header {
				max-width: 820px;
				margin: 0 auto 2em;
				text-align: center;
			}
			.meta {
				color: rgb(var(--gray));
				font-size: 0.85em;
				display: inline-flex;
				align-items: center;
				gap: 0.6em;
				flex-wrap: wrap;
				justify-content: center;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				font-weight: 600;
			}
			.meta .sep { opacity: 0.4; }
			.last-updated-on {
				font-style: italic;
				display: block;
				margin-top: 0.4em;
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.article-header h1 {
				margin: 0.7em 0 0.5em;
				font-size: 3em;
				line-height: 1.08;
				letter-spacing: -0.025em;
			}
			.hero-image {
				max-width: 1080px;
				margin: 0 auto 2em;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-md);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 0 1em 2em;
				color: rgb(var(--gray-dark));
				font-size: 1.05em;
				line-height: 1.8;
				position: relative;
			}
			.prose :global(p) { margin: 0 0 1.4em; }
			.prose :global(p > img),
			.prose :global(p > picture > img) {
				display: block;
				margin: 2.5em auto;
				max-width: 100%;
				border-radius: var(--radius-md);
				box-shadow: var(--shadow-sm);
				background: var(--surface-warm);
			}
			.prose :global(p:has(> img)),
			.prose :global(p:has(> picture)) {
				margin: 0;
				text-align: center;
			}
			.prose :global(h2) {
				margin: 2em 0 0.6em;
				scroll-margin-top: 90px;
			}
			.prose :global(h3) {
				margin: 1.5em 0 0.5em;
				scroll-margin-top: 90px;
			}
			.prose :global(hr) { margin: 2.5em 0; }
			.prose :global(table) {
				margin: 1.5em 0;
				background: var(--surface);
				border-radius: var(--radius-md);
				overflow: hidden;
				box-shadow: var(--shadow-sm);
			}
			.prose :global(table th) {
				background: var(--surface-warm);
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 0.7em 0.9em;
				font-weight: 700;
			}
			.prose :global(table td) {
				padding: 0.7em 0.9em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.prose :global(table tr:last-child td) { border-bottom: none; }
			.prose :global(blockquote) {
				margin: 1.8em 0;
				background: var(--surface-warm);
				padding: 1em 1.25em;
				border-radius: var(--radius-sm);
			}

			/* ------- TOC: dot column on right edge (minimal, never overlaps) ------- */
			/* NOTE: descendants are JS-injected after page load, so they don't
			   carry the data-astro-cid scoping attribute. They MUST be matched
			   via :global() or Astro's scoped CSS will silently skip them. */
			.toc {
				display: none;
				position: fixed;
				right: 18px;
				top: 50%;
				transform: translateY(-50%);
				max-height: 70vh;
				overflow-y: auto;
				padding: 8px 6px;
				z-index: 10;
				scrollbar-width: none;
			}
			.toc::-webkit-scrollbar { display: none; }
			.toc-title { display: none; }
			.toc :global(ol) {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 12px;
			}
			.toc :global(li) { margin: 0; position: relative; }
			.toc :global(a) {
				display: block;
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: rgba(96, 86, 73, 0.55);
				box-shadow: 0 0 0 1px rgba(96, 86, 73, 0.12);
				text-decoration: none;
				position: relative;
				transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
				cursor: pointer;
			}
			.toc :global(a:hover) {
				background: rgb(var(--gray-dark));
				transform: scale(1.3);
				box-shadow: 0 0 0 3px rgba(96, 86, 73, 0.18);
			}
			.toc :global(a.is-active) {
				background: var(--accent);
				transform: scale(1.4);
				box-shadow: 0 0 0 3px rgba(224, 120, 86, 0.22);
			}
			.toc :global(a::after) {
				content: attr(data-label);
				position: absolute;
				right: 18px;
				top: 50%;
				transform: translateY(-50%) translateX(4px);
				background: rgb(var(--gray-dark));
				color: #fff;
				font-size: 12px;
				font-weight: 500;
				padding: 5px 10px;
				border-radius: 4px;
				white-space: nowrap;
				max-width: 240px;
				overflow: hidden;
				text-overflow: ellipsis;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.15s ease, transform 0.15s ease;
				box-shadow: 0 4px 12px rgba(26, 21, 14, 0.18);
			}
			.toc :global(a::before) {
				content: '';
				position: absolute;
				right: 13px;
				top: 50%;
				transform: translateY(-50%);
				border: 5px solid transparent;
				border-left-color: rgb(var(--gray-dark));
				border-right: none;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.15s ease;
			}
			.toc :global(a:hover::after),
			.toc :global(a:hover::before),
			.toc :global(a.is-active::after),
			.toc :global(a.is-active::before) {
				opacity: 1;
				transform: translateY(-50%) translateX(0);
			}
			.toc :global(a.is-active::after) { background: var(--accent); }
			.toc :global(a.is-active::before) { border-left-color: var(--accent); }
			@media (min-width: 1024px) {
				.toc { display: block; }
			}

			/* Same issue for the JS-injected notes list inside the drawer */
			.notes-drawer :global(.notes-list) {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.8em;
			}
			.notes-drawer :global(.notes-list li) {
				background: var(--surface-warm);
				border-radius: var(--radius-sm);
				padding: 0.75em 0.9em;
				display: flex;
				justify-content: space-between;
				gap: 0.6em;
				align-items: start;
				font-size: 0.92em;
				line-height: 1.55;
			}
			.notes-drawer :global(.notes-list .quote-text) { flex: 1; }
			.notes-drawer :global(.notes-list .remove) {
				background: transparent;
				border: none;
				color: rgb(var(--gray));
				cursor: pointer;
				font-size: 16px;
				line-height: 1;
				padding: 0.2em 0.4em;
				border-radius: 4px;
				flex-shrink: 0;
			}
			.notes-drawer :global(.notes-list .remove:hover) { color: var(--danger); background: rgba(162, 39, 22, 0.06); }
			.notes-drawer :global(.notes-empty) {
				color: rgb(var(--gray));
				font-style: italic;
				padding: 1em 0;
			}
			/* Article column stays at its natural width, TOC dot column
			   only takes ~20px on the right edge so there is no overlap. */

			/* ------- Floating action buttons ------- */
			.fab-stack {
				position: fixed;
				right: 18px;
				bottom: 18px;
				display: flex;
				flex-direction: column;
				gap: 10px;
				z-index: 60;
				pointer-events: none;
			}
			.fab {
				pointer-events: auto;
				width: 44px;
				height: 44px;
				border-radius: 999px;
				background: rgb(var(--gray-dark));
				color: #fff;
				border: none;
				cursor: pointer;
				box-shadow: var(--shadow-md);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				opacity: 0;
				transform: translateY(8px);
				transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease;
				font-size: 18px;
				line-height: 1;
			}
			.fab.is-visible {
				opacity: 1;
				transform: none;
			}
			.fab:hover {
				background: var(--accent-dark);
			}
			.fab.has-badge {
				position: relative;
			}
			.fab .badge {
				position: absolute;
				top: -4px;
				right: -4px;
				min-width: 18px;
				height: 18px;
				padding: 0 5px;
				border-radius: 999px;
				background: var(--accent);
				color: #fff;
				font-size: 11px;
				font-weight: 700;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				box-shadow: 0 0 0 2px var(--bg);
			}

			/* ------- Selection popover ------- */
			.sel-pop {
				position: absolute;
				z-index: 70;
				display: none;
				background: rgb(var(--gray-dark));
				color: #fff;
				border-radius: 999px;
				padding: 0.3em 0.4em;
				box-shadow: var(--shadow-lg);
				font-size: 13px;
				gap: 0.15em;
			}
			.sel-pop.is-open { display: inline-flex; }
			.sel-pop::after {
				content: '';
				position: absolute;
				bottom: -5px;
				left: 50%;
				transform: translateX(-50%);
				border: 5px solid transparent;
				border-top-color: rgb(var(--gray-dark));
				border-bottom: none;
			}
			.sel-pop button {
				background: transparent;
				border: none;
				color: #fff;
				cursor: pointer;
				padding: 0.35em 0.75em;
				border-radius: 999px;
				font-size: 13px;
				font-weight: 600;
				transition: background 0.15s ease;
			}
			.sel-pop button:hover { background: rgba(255, 255, 255, 0.15); }
			.sel-pop button.done {
				background: var(--accent);
				color: #fff;
			}

			/* ------- Saved quotes drawer ------- */
			.notes-drawer {
				position: fixed;
				left: 0;
				right: 0;
				bottom: 0;
				background: var(--surface);
				border-top: 1px solid rgb(var(--gray-light));
				box-shadow: var(--shadow-lg);
				transform: translateY(100%);
				transition: transform 0.22s ease;
				z-index: 80;
				max-height: 70vh;
				overflow-y: auto;
			}
			.notes-drawer.is-open { transform: none; }
			.notes-inner {
				max-width: 720px;
				margin: 0 auto;
				padding: 1.25em 1.25em 1.5em;
			}
			.notes-head {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.8em;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.6em;
			}
			.notes-head h3 {
				margin: 0;
				font-size: 1.1em;
				font-family: var(--font-serif);
			}
			.notes-head button {
				background: transparent;
				border: none;
				font-size: 22px;
				line-height: 1;
				cursor: pointer;
				color: rgb(var(--gray));
				padding: 0.1em 0.3em;
				border-radius: 4px;
			}
			.notes-head button:hover { color: rgb(var(--black)); background: var(--surface-warm); }
			/* .notes-list and .notes-empty styles are defined as :global() above, 			   the elements are injected by JS and don't carry Astro's scoping attr. */

			@media (max-width: 720px) {
				.article-header h1 { font-size: 2em; }
				.prose { font-size: 1em; line-height: 1.7; padding: 0 0.5em 1em; }
				.fab { width: 40px; height: 40px; font-size: 16px; }
				.fab-stack { right: 12px; bottom: 12px; }
			}

			@media (prefers-reduced-motion: reduce) {
				.fab, .sel-pop, .notes-drawer, .toc a {
					transition: none !important;
				}
			}
		</style>
	</head>

	<body>
		<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
		<Header />

		<nav class="toc" id="toc" aria-label="On this page" hidden>
			<span class="toc-title">On this page</span>
			<ol id="toc-list"></ol>
		</nav>

		<main>
			<article id="article">
				<header class="article-header">
					<div class="meta">
						<FormattedDate date={pubDate} />
						{readingTime && (
							<>
								<span class="sep">·</span>
								<span>{readingTime} min read</span>
							</>
						)}
					</div>
					{
						updatedDate && (
							<div class="last-updated-on">
								Last updated on <FormattedDate date={updatedDate} />
							</div>
						)
					}
					<h1>{title}</h1>
				</header>
				{heroImage && (
					<div class="hero-image">
						<Image width={1200} height={675} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose" id="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />

		<!-- Selection popover -->
		<div class="sel-pop" id="sel-pop" role="toolbar" aria-label="Selection actions">
			<button type="button" data-action="copy" title="Copy selected text">Copy</button>
			<button type="button" data-action="save" title="Save this quote">Save quote</button>
		</div>

		<!-- Floating buttons: notes + back to top -->
		<div class="fab-stack">
			<button type="button" class="fab has-badge" id="fab-notes" aria-label="View saved quotes" title="Saved quotes">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
				<span class="badge" id="notes-badge" hidden>0</span>
			</button>
			<button type="button" class="fab" id="fab-top" aria-label="Back to top" title="Back to top">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
			</button>
		</div>

		<!-- Saved quotes drawer -->
		<aside class="notes-drawer" id="notes-drawer" aria-hidden="true">
			<div class="notes-inner">
				<div class="notes-head">
					<h3>Your saved quotes from this article</h3>
					<button type="button" id="notes-close" aria-label="Close">×</button>
				</div>
				<div id="notes-body"></div>
			</div>
		</aside>

		<script>
			(function () {
				const STORAGE_PREFIX = 'tb-notes:';
				const articleEl = document.getElementById('article');
				const proseEl = document.getElementById('prose');
				const progressBar = document.getElementById('reading-progress');
				const tocEl = document.getElementById('toc');
				const tocListEl = document.getElementById('toc-list');
				const fabTop = document.getElementById('fab-top');
				const fabNotes = document.getElementById('fab-notes');
				const notesBadge = document.getElementById('notes-badge');
				const drawer = document.getElementById('notes-drawer');
				const drawerClose = document.getElementById('notes-close');
				const notesBody = document.getElementById('notes-body');
				const selPop = document.getElementById('sel-pop');

				if (!articleEl || !proseEl) return;

				const storageKey = STORAGE_PREFIX + location.pathname;

				// ---------- Reading progress ----------
				if (progressBar) {
					let ticking = false;
					const update = () => {
						const rect = articleEl.getBoundingClientRect();
						const top = rect.top + window.scrollY;
						const end = top + articleEl.scrollHeight - window.innerHeight;
						const range = Math.max(1, end - top);
						const p = Math.max(0, Math.min(1, (window.scrollY - top) / range));
						progressBar.style.width = p * 100 + '%';
						ticking = false;
					};
					const onScroll = () => {
						if (!ticking) { requestAnimationFrame(update); ticking = true; }
					};
					window.addEventListener('scroll', onScroll, { passive: true });
					window.addEventListener('resize', onScroll);
					update();
				}

				// ---------- TOC build ----------
				const slugify = (s) =>
					s.toLowerCase()
						.replace(/[^\w\s-]/g, '')
						.replace(/\s+/g, '-')
						.replace(/^-+|-+$/g, '')
						.slice(0, 64);
				const headings = Array.from(proseEl.querySelectorAll('h2'));
				const usedIds = new Set();
				const tocItems = headings.map((h) => {
					let id = h.id || slugify(h.textContent || '');
					let base = id; let n = 2;
					while (usedIds.has(id)) { id = base + '-' + n; n++; }
					usedIds.add(id);
					h.id = id;
					return { id, text: h.textContent || '', el: h };
				});
				if (tocItems.length >= 2 && tocListEl && tocEl) {
					tocEl.hidden = false;
					const esc = (s) => s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
					tocListEl.innerHTML = tocItems
						.map((it) => `<li><a href="#${it.id}" data-id="${it.id}" data-label="${esc(it.text)}" aria-label="${esc(it.text)}"></a></li>`)
						.join('');
					const anchors = Array.from(tocListEl.querySelectorAll('a'));
					anchors.forEach((a) =>
						a.addEventListener('click', (e) => {
							const id = a.getAttribute('data-id');
							const target = id && document.getElementById(id);
							if (!target) return;
							e.preventDefault();
							const y = target.getBoundingClientRect().top + window.scrollY - 80;
							window.scrollTo({ top: y, behavior: 'smooth' });
							history.replaceState(null, '', '#' + id);
						})
					);
					const setActive = (id) => {
						anchors.forEach((a) => {
							a.classList.toggle('is-active', a.getAttribute('data-id') === id);
						});
					};
					// Start with the first section active so users always see an orange anchor
					setActive(tocItems[0].id);
					if ('IntersectionObserver' in window) {
						const io = new IntersectionObserver(
							(entries) => {
								const visible = entries
									.filter((e) => e.isIntersecting)
									.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
								if (visible) setActive(visible.target.id);
							},
							{ rootMargin: '-80px 0px -65% 0px', threshold: 0 }
						);
						tocItems.forEach((it) => io.observe(it.el));
					}
				}

				// ---------- FAB visibility ----------
				const updateFabs = () => {
					const show = window.scrollY > 500;
					fabTop && fabTop.classList.toggle('is-visible', show);
					if (fabNotes) {
						const hasNotes = readNotes().length > 0;
						fabNotes.classList.toggle('is-visible', show || hasNotes);
					}
				};
				window.addEventListener('scroll', updateFabs, { passive: true });
				updateFabs();

				fabTop && fabTop.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});

				// ---------- Saved quotes storage ----------
				function readNotes() {
					try {
						const raw = localStorage.getItem(storageKey);
						if (!raw) return [];
						const parsed = JSON.parse(raw);
						return Array.isArray(parsed) ? parsed : [];
					} catch (e) { return []; }
				}
				function writeNotes(arr) {
					try { localStorage.setItem(storageKey, JSON.stringify(arr)); } catch (e) {}
					renderNotes();
				}
				function addNote(text) {
					const arr = readNotes();
					const clean = (text || '').trim();
					if (!clean) return;
					if (arr.some((n) => n.text === clean)) return;
					arr.push({ text: clean, at: Date.now() });
					writeNotes(arr);
				}
				function removeNote(at) {
					writeNotes(readNotes().filter((n) => n.at !== at));
				}
				function renderNotes() {
					const arr = readNotes();
					if (notesBadge) {
						notesBadge.textContent = String(arr.length);
						notesBadge.hidden = arr.length === 0;
					}
					if (notesBody) {
						if (!arr.length) {
							notesBody.innerHTML = '<p class="notes-empty">No quotes saved yet. Highlight any text in the article and tap "Save quote".</p>';
						} else {
							const items = arr
								.slice()
								.reverse()
								.map(
									(n) =>
										`<li><span class="quote-text">"${n.text.replace(/</g, '&lt;')}"</span><button class="remove" type="button" data-at="${n.at}" aria-label="Remove quote">×</button></li>`
								)
								.join('');
							notesBody.innerHTML = '<ul class="notes-list">' + items + '</ul>';
							notesBody.querySelectorAll('.remove').forEach((btn) => {
								btn.addEventListener('click', () => removeNote(Number(btn.getAttribute('data-at'))));
							});
						}
					}
					updateFabs();
				}
				renderNotes();

				// ---------- Notes drawer ----------
				function openDrawer() {
					drawer && drawer.classList.add('is-open');
					drawer && drawer.setAttribute('aria-hidden', 'false');
				}
				function closeDrawer() {
					drawer && drawer.classList.remove('is-open');
					drawer && drawer.setAttribute('aria-hidden', 'true');
				}
				fabNotes && fabNotes.addEventListener('click', openDrawer);
				drawerClose && drawerClose.addEventListener('click', closeDrawer);
				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape') closeDrawer();
				});

				// ---------- Selection popover ----------
				let lastSelectionText = '';
				function showPop(rect, sel) {
					if (!selPop) return;
					lastSelectionText = sel;
					selPop.style.opacity = '0';
					selPop.classList.add('is-open');
					const popRect = selPop.getBoundingClientRect();
					const top = window.scrollY + rect.top - popRect.height - 10;
					const left = window.scrollX + rect.left + rect.width / 2 - popRect.width / 2;
					const maxLeft = Math.max(8, window.scrollX + window.innerWidth - popRect.width - 8);
					selPop.style.top = Math.max(window.scrollY + 60, top) + 'px';
					selPop.style.left = Math.min(Math.max(8, left), maxLeft) + 'px';
					selPop.style.opacity = '1';
					// Reset any "done" state on buttons
					selPop.querySelectorAll('button').forEach((b) => {
						b.classList.remove('done');
						const a = b.getAttribute('data-action');
						b.textContent = a === 'copy' ? 'Copy' : 'Save quote';
					});
				}
				function hidePop() {
					if (selPop) selPop.classList.remove('is-open');
				}
				function handleSelection() {
					const sel = window.getSelection();
					if (!sel || sel.isCollapsed) { hidePop(); return; }
					const text = sel.toString().trim();
					if (text.length < 5) { hidePop(); return; }
					// Selection must be inside prose
					const range = sel.getRangeAt(0);
					if (!proseEl.contains(range.commonAncestorContainer)) { hidePop(); return; }
					const rect = range.getBoundingClientRect();
					if (rect.width === 0 && rect.height === 0) { hidePop(); return; }
					showPop(rect, text);
				}
				document.addEventListener('mouseup', () => setTimeout(handleSelection, 10));
				document.addEventListener('touchend', () => setTimeout(handleSelection, 10), { passive: true });
				document.addEventListener('scroll', hidePop, { passive: true });
				document.addEventListener('mousedown', (e) => {
					if (selPop && !selPop.contains(e.target)) {
						// Let mouseup re-evaluate
						setTimeout(() => {
							const s = window.getSelection();
							if (!s || s.isCollapsed) hidePop();
						}, 0);
					}
				});

				selPop && selPop.querySelectorAll('button').forEach((btn) => {
					btn.addEventListener('click', (e) => {
						e.preventDefault();
						const action = btn.getAttribute('data-action');
						if (!lastSelectionText) return;
						if (action === 'copy') {
							const finish = () => {
								btn.classList.add('done');
								btn.textContent = 'Copied!';
								setTimeout(hidePop, 700);
							};
							if (navigator.clipboard && navigator.clipboard.writeText) {
								navigator.clipboard.writeText(lastSelectionText).then(finish).catch(finish);
							} else {
								try {
									const ta = document.createElement('textarea');
									ta.value = lastSelectionText;
									document.body.appendChild(ta);
									ta.select(); document.execCommand('copy');
									document.body.removeChild(ta);
								} catch (e) {}
								finish();
							}
						} else if (action === 'save') {
							addNote(lastSelectionText);
							btn.classList.add('done');
							btn.textContent = 'Saved!';
							setTimeout(hidePop, 700);
						}
					});
				});
			})();
		</script>
	</body>
</html>
