---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{
	posts.length > 0 && (
		<section class="related" aria-label="Related articles">
			<div class="related-inner">
				<span class="related-eyebrow">Keep reading</span>
				<h2 class="related-title">Related reads</h2>
				<ul class="related-grid">
					{posts.map((p) => (
						<li class="related-card">
							<a href={`/blog/${p.id}/`}>
								{p.data.heroImage && (
									<div class="thumb">
										<Image src={p.data.heroImage} alt="" width={480} height={270} />
									</div>
								)}
								<div class="card-body">
									<h3>{p.data.title}</h3>
									<p>{p.data.description}</p>
									<span class="read-more">Read article &rarr;</span>
								</div>
							</a>
						</li>
					))}
				</ul>
			</div>
		</section>
	)
}

<style>
	.related {
		border-top: 1px solid rgb(var(--gray-light));
		background: var(--surface-warm);
		padding: 3em 1.25em 3.5em;
	}
	.related-inner {
		max-width: var(--max-w-content);
		margin: 0 auto;
	}
	.related-eyebrow {
		display: block;
		font-size: 0.75em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent-dark);
		margin-bottom: 0.3em;
	}
	.related-title {
		margin: 0 0 1.2em;
		font-family: var(--font-serif);
		font-size: 1.7em;
		letter-spacing: -0.02em;
		color: rgb(var(--black));
	}
	.related-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.4em;
	}
	.related-card {
		margin: 0;
	}
	.related-card a {
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--surface);
		border: 1px solid rgb(var(--gray-light));
		border-radius: var(--radius-lg);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
	}
	.related-card a:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
		border-color: rgba(var(--gray), 0.4);
	}
	.thumb {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--surface-warm);
	}
	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.card-body {
		padding: 1em 1.1em 1.2em;
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		flex: 1;
	}
	.card-body h3 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: 1.08em;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: rgb(var(--black));
	}
	.card-body p {
		margin: 0;
		font-size: 0.9em;
		line-height: 1.5;
		color: rgb(var(--gray));
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.read-more {
		margin-top: auto;
		padding-top: 0.6em;
		font-size: 0.82em;
		font-weight: 700;
		color: var(--accent-dark);
	}
	@media (max-width: 860px) {
		.related-grid { grid-template-columns: 1fr 1fr; }
	}
	@media (max-width: 560px) {
		.related { padding: 2.5em 1em 3em; }
		.related-grid { grid-template-columns: 1fr; gap: 1em; }
	}
</style>
