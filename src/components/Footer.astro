---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="brand-block">
			<span class="brand-mark">Toolbase</span>
			<p class="tag">The honest filter for AI tools that one-person businesses actually use.</p>
		</div>
		<nav class="links" aria-label="Footer">
			<a href="/tools/">Tools</a>
			<a href="/blog/">Blog</a>
			<a href="/about/">About</a>
		</nav>
		<nav class="links tools-col" aria-label="Popular tools">
			<span class="col-label">Popular tools</span>
			<a href="/tools/freelance-rate-calculator/">Rate calculator</a>
			<a href="/tools/merge-pdf/">Merge PDF</a>
			<a href="/tools/compress-image/">Compress image</a>
			<a href="/tools/word-counter/">Word counter</a>
			<a href="/tools/">All tools →</a>
		</nav>
		<div class="legal">
			<nav class="legal-links" aria-label="Legal">
				<a href="/privacy/">Privacy</a>
				<a href="/terms/">Terms</a>
				<a href="/contact/">Contact</a>
			</nav>
			<p class="copyright">&copy; {today.getFullYear()} Toolbase</p>
			<p class="disclosure">
				We only recommend tools we'd use ourselves. Some outbound links may be affiliate links,
				which never changes what we recommend or costs you anything.
			</p>
		</div>
	</div>
</footer>
<style>
	footer {
		margin-top: 4em;
		padding: 3em 1.25em 4em;
		background: linear-gradient(to bottom, var(--bg), var(--surface-warm));
		border-top: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
	}
	.footer-inner {
		max-width: var(--max-w-content);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1.6fr 0.9fr 1.1fr 1.5fr;
		gap: 2em;
		align-items: start;
	}
	.col-label {
		font-size: 0.72em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		margin-bottom: 0.2em;
	}
	.brand-mark {
		font-family: var(--font-serif);
		font-size: 1.4em;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: rgb(var(--black));
		display: block;
		margin-bottom: 0.4em;
	}
	.tag {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin: 0;
		line-height: 1.5;
	}
	.links {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		padding-top: 0.3em;
	}
	.links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.95em;
		font-weight: 500;
	}
	.links a:hover { color: var(--accent-dark); }
	.legal {
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.legal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9em;
		margin-bottom: 0.7em;
	}
	.legal-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.9em;
		font-weight: 600;
	}
	.legal-links a:hover { color: var(--accent-dark); }
	.copyright {
		margin: 0 0 0.5em;
		font-weight: 700;
		color: rgb(var(--gray-dark));
	}
	.disclosure {
		margin: 0;
		line-height: 1.55;
	}
	.disclosure a {
		color: var(--accent-dark);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
	}
	@media (max-width: 720px) {
		footer { padding: 2.5em 1em 3em; }
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
		.links { flex-direction: row; flex-wrap: wrap; gap: 1em; padding-top: 0; }
		.tools-col { flex-direction: column; gap: 0.5em; }
		.col-label { width: 100%; }
	}
</style>
